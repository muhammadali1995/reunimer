---
/**
 * "Implantations & Flux Commerciaux" Section
 *
 * Figma nodes: 729:3098 (bg), 729:3107–729:3199 (y=5964–~8000)
 * Dark bg (bleu-abysse), two sub-sections:
 *   1. "L'implantation de nos filiales" — title + desc + 3 regional maps
 *   2. "Les flux commerciaux" — title + desc + world map with pins
 *
 * Maps: SVG silhouettes (La Réunion, Madagascar, France)
 * World map: PNG raster (2680×1557) with positioned labels + pins
 *
 * Pins have GSAP-powered pulsing glow rings and hover tooltips.
 */

import { Image } from 'astro:assets';
import worldMapImage from '../../assets/images/groupe/world-map.png';
import { reunionPins, madagascarPins, francePins, worldPins } from '../../data/groupe';

interface Props {
  id?: string;
}

const { id = 'implantations' } = Astro.props;

// Route data: destinations for each world pin (coordinates in 1340×779 viewBox)
// Pin 0 - France (648.5, 293.5), Pin 1 - Madagascar (820.5, 573.5), Pin 2 - Réunion (854.5, 579.5)
const pinOrigins = [
  { x: 648.5, y: 293.5 },
  { x: 820.5, y: 573.5 },
  { x: 854.5, y: 579.5 },
];
const pinDestinations = [
  // France → various destinations + USA (e.g., [299, 229])
  [[408, 424], [410, 435], [853, 574], [813, 542], [861, 570], [853, 510], [1124, 586], [981, 343], [299, 229]],
  // Madagascar → 3 destinations
  [[1120, 605], [1276, 714], [1160, 330]],
  // Réunion → 8 destinations
  [[697, 296], [1082, 399], [979, 345], [1044, 489], [1040, 475], [1056, 441], [289, 323], [299, 229]],
];

// Compute quadratic bezier curves with globe-like upward arc
function computeRoute(px: number, py: number, dx: number, dy: number): string {
  const midX = (px + dx) / 2;
  const midY = (py + dy) / 2;
  const dist = Math.sqrt((dx - px) ** 2 + (dy - py) ** 2);
  const ctrlX = midX;
  const ctrlY = midY - dist * 0.15;
  return `M${px},${py} Q${ctrlX},${ctrlY} ${dx},${dy}`;
}

const routeGroups = pinOrigins.map((pin, i) => ({
  paths: pinDestinations[i].map(([dx, dy]) => computeRoute(pin.x, pin.y, dx, dy)),
}));
---

<section id={id} class="scroll-mt-[135px] bg-bleu-abysse">
  <!-- Part 1: L'implantation de nos filiales -->
  <div class="pt-16 md:pt-24 lg:pt-[120px] pb-12 md:pb-16 lg:pb-20">
    <div class="mx-auto w-full max-w-[1284px] px-5 md:px-10 lg:px-0">
      <!-- Title -->
      <h2 class="font-display font-extrabold text-[28px] leading-[1.2] md:text-display-lg uppercase text-white text-center max-w-[922px] mx-auto">
        L'implantation<br />de nos filiales
      </h2>

      <!-- Description -->
      <p class="mt-5 md:mt-6 font-heading font-normal text-base md:text-xl md:leading-[1.461] text-white text-center max-w-[820px] mx-auto">
        De La Réunion à Madagascar, en passant par les places fortes du mareyage français comme Boulogne-sur-Mer et Lorient, le Groupe conjugue puissance industrielle et ancrage local. Cette présence multi-sites nous permet d'offrir une diversité exceptionnelle de produits, des pélagiques aux crustacés.
      </p>

      <!-- Regional Maps -->
      <div class="mt-12 md:mt-16 lg:mt-20 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-8 lg:gap-12" data-stagger>

        <!-- La Réunion -->
        <div class="flex flex-col items-center">
          <div class="h-[180px] md:h-[200px] lg:h-[246px] flex items-end justify-center">
            <div class="relative w-auto max-h-full">
              <img src="/images/groupe/map-reunion.svg" alt="Carte de La Réunion" width="191" height="168" class="w-auto max-h-[180px] md:max-h-[200px] lg:max-h-[246px]" loading="lazy" />
              {reunionPins.map((pin) => (
                <div class="map-pin absolute -translate-x-1/2 -translate-y-1/2 z-10" style={`top: ${pin.top}; left: ${pin.left};`}>
                  <span class="pin-ring absolute inset-[-6px] md:inset-[-8px] rounded-full border border-white/60" />
                  <span class="pin-dot block w-[8px] h-[8px] md:w-[10px] md:h-[10px] rounded-full bg-white" />
                  <div class="pin-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 pointer-events-none opacity-0 invisible">
                    <div class="relative bg-white/80 backdrop-blur-sm rounded-lg px-4 py-3 min-w-[160px] md:min-w-[200px]">
                      <p class="font-heading font-bold text-[13px] md:text-[15px] text-bleu-abysse leading-tight text-center">{pin.name}</p>
                      <p class="font-body font-normal text-[11px] md:text-[13px] text-bleu-abysse/70 leading-snug mt-1 text-center">{pin.desc}</p>
                      <span class="absolute top-full left-1/2 -translate-x-1/2 w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-t-[8px] border-t-white/80" />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <p class="mt-6 font-heading font-semibold text-lg md:text-xl text-white text-center tracking-[-1px]">La Réunion</p>
          <p class="mt-1 font-body font-normal text-sm md:text-body-base text-white text-center max-w-[279px]">Armement, transformation, distribution, pilotage groupe</p>
        </div>

        <!-- Madagascar -->
        <div class="flex flex-col items-center md:-ml-16 lg:-ml-24">
          <div class="h-[180px] md:h-[200px] lg:h-[246px] flex items-end justify-center">
            <div class="relative w-auto max-h-full">
              <img src="/images/groupe/map-madagascar.svg" alt="Carte de Madagascar" width="125" height="246" class="w-auto max-h-[180px] md:max-h-[200px] lg:max-h-[246px]" loading="lazy" />
              {madagascarPins.map((pin) => (
                <div class="map-pin absolute -translate-x-1/2 -translate-y-1/2 z-10" style={`top: ${pin.top}; left: ${pin.left};`}>
                  <span class="pin-ring absolute inset-[-6px] md:inset-[-8px] rounded-full border border-white/60" />
                  <span class="pin-dot block w-[8px] h-[8px] md:w-[10px] md:h-[10px] rounded-full bg-white" />
                  <div class="pin-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 pointer-events-none opacity-0 invisible">
                    <div class="relative bg-white/80 backdrop-blur-sm rounded-lg px-4 py-3 min-w-[160px] md:min-w-[200px]">
                      <p class="font-heading font-bold text-[13px] md:text-[15px] text-bleu-abysse leading-tight text-center">{pin.name}</p>
                      <p class="font-body font-normal text-[11px] md:text-[13px] text-bleu-abysse/70 leading-snug mt-1 text-center">{pin.desc}</p>
                      <span class="absolute top-full left-1/2 -translate-x-1/2 w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-t-[8px] border-t-white/80" />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <p class="mt-6 font-heading font-semibold text-lg md:text-xl text-white text-center tracking-[-1px]">Madagascar</p>
          <p class="mt-1 font-body font-normal text-sm md:text-body-base text-white text-center max-w-[279px]">Collecte artisanale, transformation, algoculture durable.</p>
        </div>

        <!-- France métropolitaine -->
        <div class="flex flex-col items-center">
          <div class="h-[180px] md:h-[200px] lg:h-[246px] flex items-end justify-center">
            <div class="relative w-auto max-h-full">
              <img src="/images/groupe/map-france.svg" alt="Carte de France métropolitaine" width="231" height="212" class="w-auto max-h-[180px] md:max-h-[200px] lg:max-h-[246px]" loading="lazy" />
              {francePins.map((pin) => (
                <div class="map-pin absolute -translate-x-1/2 -translate-y-1/2 z-10" style={`top: ${pin.top}; left: ${pin.left};`}>
                  <span class="pin-ring absolute inset-[-6px] md:inset-[-8px] rounded-full border border-white/60" />
                  <span class="pin-dot block w-[8px] h-[8px] md:w-[10px] md:h-[10px] rounded-full bg-white" />
                  <div class="pin-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 pointer-events-none opacity-0 invisible">
                    <div class="relative bg-white/80 backdrop-blur-sm rounded-lg px-4 py-3 min-w-[160px] md:min-w-[200px]">
                      <p class="font-heading font-bold text-[13px] md:text-[15px] text-bleu-abysse leading-tight text-center">{pin.name}</p>
                      <p class="font-body font-normal text-[11px] md:text-[13px] text-bleu-abysse/70 leading-snug mt-1 text-center">{pin.desc}</p>
                      <span class="absolute top-full left-1/2 -translate-x-1/2 w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-t-[8px] border-t-white/80" />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <p class="mt-6 font-heading font-semibold text-lg md:text-xl text-white text-center tracking-[-1px]">France métropolitaine</p>
          <p class="mt-1 font-body font-normal text-sm md:text-body-base text-white text-center max-w-[279px]">Mareyage, transformation, distribution et importation.</p>
        </div>

      </div>
    </div>
  </div>

  <!-- Part 2: Les flux commerciaux -->
  <div class="pb-16 md:pb-24 lg:pb-[120px]">
    <div class="mx-auto w-full max-w-[1284px] px-5 md:px-10 lg:px-0">
      <!-- Title -->
      <h2 class="font-display font-extrabold text-[28px] leading-[1.2] md:text-display-lg uppercase text-white text-center max-w-[922px] mx-auto">
        Les flux<br />commerciaux
      </h2>

      <!-- Description -->
      <p class="mt-5 md:mt-6 font-heading font-normal text-base md:text-xl md:leading-[1.461] text-white text-center max-w-[820px] mx-auto">
        Le groupe Reunimer déploie son expertise à travers trois hubs stratégiques, créant un pont direct entre les ressources de l'Océan Indien et les marchés européens.
      </p>

      <!-- World Map -->
      <div class="mt-12 md:mt-16 lg:mt-20 relative w-full max-w-[1340px] mx-auto">
        <Image
          src={worldMapImage}
          alt="Carte du monde montrant les flux commerciaux du groupe Reunimer entre la France, Madagascar et La Réunion"
          class="w-full h-auto"
          widths={[375, 768, 1024, 1340]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 90vw, 1340px"
        />

        <!-- Flux overlay images (one per pin, shown on hover) -->
        {worldPins.map((pin, i) => (
          <img
            src={pin.fluxImage}
            alt=""
            class="world-flux-overlay absolute inset-0 w-full h-full object-cover pointer-events-none"
            style="clip-path: circle(0% at 50% 50%);"
            data-flux-index={i}
            loading="lazy"
          />
        ))}

        <!-- Animated route lines (drawing animation on hover) -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none z-[6]" viewBox="0 0 1340 779" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          {routeGroups.map((group, gi) => (
            <g data-route-group={gi} style="opacity:0">
              {group.paths.map((d) => (
                <path
                  d={d}
                  fill="none"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.7"
                  data-route-path
                />
              ))}
            </g>
          ))}
        </svg>

        <!-- Pins -->
        {worldPins.map((pin, i) => (
          <div class="world-map-pin absolute -translate-x-1/2 -translate-y-1/2 z-10 cursor-pointer" style={`top: ${pin.top}; left: ${pin.left};`} data-pin-index={i}>
            <span class="pin-ring absolute inset-[-6px] md:inset-[-8px] rounded-full border border-turquoise-ocean/60" />
            <span class="pin-dot block w-[10px] h-[10px] md:w-[15px] md:h-[15px] rounded-full bg-white border-2 border-turquoise-ocean" />
          </div>
        ))}

        <!-- Labels -->
        <span
          class="absolute hidden md:block font-heading font-medium text-[10px] lg:text-[14px] text-white uppercase tracking-[5px] text-center -translate-x-1/2"
          style="top: 39.85%; left: 47%;"
        >
          France<br />métropolitaine
        </span>
        <span
          class="absolute hidden md:block font-heading font-medium text-[10px] lg:text-[14px] text-white uppercase tracking-[5px]"
          style="top: 72.36%; left: 46%;"
        >
          Madagascar
        </span>
        <span
          class="absolute hidden md:block font-heading font-medium text-[10px] lg:text-[14px] text-white uppercase tracking-[5px]"
          style="top: 73.13%; left: 66%;"
        >
          La Réunion
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  function initMapPins() {
    // --- Regional map pins (glow + tooltip) ---
    const pins = document.querySelectorAll('.map-pin');

    pins.forEach((pin, index) => {
      const ring = pin.querySelector('.pin-ring') as HTMLElement;
      const tooltip = pin.querySelector('.pin-tooltip') as HTMLElement;

      if (!ring) return;

      // Staggered pulsing glow animation on the ring
      gsap.to(ring, {
        scale: 1.6,
        opacity: 0,
        duration: 1.5,
        repeat: -1,
        ease: 'power1.out',
        delay: index * 0.2,
      });

      // Keep a steady ring visible underneath the pulsing one
      const steadyRing = ring.cloneNode(true) as HTMLElement;
      steadyRing.classList.remove('pin-ring');
      steadyRing.classList.add('pin-ring-steady');
      pin.insertBefore(steadyRing, ring);

      gsap.set(steadyRing, { opacity: 0.3 });

      // Hover tooltip
      if (!tooltip) return;

      const pinEl = pin as HTMLElement;
      pinEl.style.cursor = 'pointer';

      pinEl.addEventListener('mouseenter', () => {
        gsap.killTweensOf(tooltip);
        gsap.set(tooltip, { visibility: 'visible', pointerEvents: 'auto' });
        gsap.to(tooltip, {
          opacity: 1,
          y: 0,
          duration: 0.25,
          ease: 'power2.out',
        });
      });

      pinEl.addEventListener('mouseleave', () => {
        gsap.killTweensOf(tooltip);
        gsap.to(tooltip, {
          opacity: 0,
          y: 4,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => {
            gsap.set(tooltip, { visibility: 'hidden', pointerEvents: 'none' });
          },
        });
      });

      gsap.set(tooltip, { opacity: 0, y: 4, visibility: 'hidden' });
    });

    // --- World map pins (glow + route drawing + flux overlay on hover) ---
    const worldMapPins = document.querySelectorAll('.world-map-pin');
    const fluxOverlays = document.querySelectorAll('.world-flux-overlay');

    worldMapPins.forEach((pin, index) => {
      const ring = pin.querySelector('.pin-ring') as HTMLElement;

      if (!ring) return;

      // Pulsing glow
      gsap.to(ring, {
        scale: 1.6,
        opacity: 0,
        duration: 1.5,
        repeat: -1,
        ease: 'power1.out',
        delay: index * 0.3,
      });

      const steadyRing = ring.cloneNode(true) as HTMLElement;
      steadyRing.classList.remove('pin-ring');
      steadyRing.classList.add('pin-ring-steady');
      pin.insertBefore(steadyRing, ring);
      gsap.set(steadyRing, { opacity: 0.3 });

      // Find matching flux overlay and route group
      const pinIndex = (pin as HTMLElement).dataset.pinIndex;
      const overlay = document.querySelector(`.world-flux-overlay[data-flux-index="${pinIndex}"]`) as HTMLElement;
      const routeGroup = document.querySelector(`[data-route-group="${pinIndex}"]`) as SVGGElement;

      if (!overlay) return;

      const pinEl = pin as HTMLElement;

      // Pin position as clip-path origin (percentage-based)
      const pinLeft = pinEl.style.left;
      const pinTop = pinEl.style.top;

      // Set initial clip-path for overlay
      overlay.style.clipPath = `circle(0% at ${pinLeft} ${pinTop})`;
      overlay.style.opacity = '1';

      // Set initial state for route paths (hidden via stroke-dashoffset)
      const routePaths = routeGroup?.querySelectorAll('[data-route-path]') as NodeListOf<SVGPathElement>;
      if (routePaths) {
        routePaths.forEach((path) => {
          const length = path.getTotalLength();
          path.style.strokeDasharray = `${length}`;
          path.style.strokeDashoffset = `${length}`;
        });
      }

      pinEl.addEventListener('mouseenter', () => {
        // Reset all other overlays and route groups
        fluxOverlays.forEach((o) => {
          const el = o as HTMLElement;
          if (el !== overlay) {
            gsap.to(el, {
              clipPath: `circle(0% at ${el.dataset.clipOriginLeft || '50%'} ${el.dataset.clipOriginTop || '50%'})`,
              duration: 0.3,
              ease: 'power2.in',
            });
          }
        });
        document.querySelectorAll('[data-route-group]').forEach((g) => {
          if (g !== routeGroup) {
            gsap.to(g, { opacity: 0, duration: 0.2 });
          }
        });

        // Animate route lines drawing from pin to destinations
        if (routeGroup && routePaths) {
          gsap.set(routeGroup, { opacity: 1 });
          routePaths.forEach((path, i) => {
            gsap.to(path, {
              strokeDashoffset: 0,
              duration: 1,
              ease: 'power2.inOut',
              delay: i * 0.06,
            });
          });
        }

        // Reveal flux overlay (labels) with slight delay so lines draw first
        gsap.to(overlay, {
          clipPath: `circle(150% at ${pinLeft} ${pinTop})`,
          duration: 0.8,
          ease: 'power2.out',
          delay: 0.3,
        });

        // Hide other world pins
        worldMapPins.forEach((otherPin) => {
          if (otherPin !== pin) {
            gsap.to(otherPin, { opacity: 0, duration: 0.25, ease: 'power2.out' });
          }
        });
      });

      pinEl.addEventListener('mouseleave', () => {
        // Collapse overlay
        gsap.to(overlay, {
          clipPath: `circle(0% at ${pinLeft} ${pinTop})`,
          duration: 0.4,
          ease: 'power2.in',
        });

        // Un-draw route lines
        if (routeGroup && routePaths) {
          routePaths.forEach((path) => {
            const length = path.getTotalLength();
            gsap.to(path, {
              strokeDashoffset: length,
              duration: 0.4,
              ease: 'power2.in',
            });
          });
          gsap.to(routeGroup, { opacity: 0, delay: 0.4, duration: 0.1 });
        }

        // Restore other world pins
        worldMapPins.forEach((otherPin) => {
          if (otherPin !== pin) {
            gsap.to(otherPin, { opacity: 1, duration: 0.3, ease: 'power2.out' });
          }
        });
      });

      // Store origin for other overlays to reference during reset
      overlay.dataset.clipOriginLeft = pinLeft;
      overlay.dataset.clipOriginTop = pinTop;
    });
  }

  function initImplantations() {
    initMapPins();
  }

  // Run on page load and Astro view transitions
  document.addEventListener('astro:page-load', initImplantations);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImplantations);
  } else {
    initImplantations();
  }
</script>
