---
import { Image } from 'astro:assets';
import Container from '../../ui/Container.astro';
import { brandRows } from '../../../data/expertises';
---

<section class="relative bg-white py-16 text-bleu-abysse md:py-[96px]">
  <div class="absolute inset-x-0 top-0 h-[22px] bg-sable-corail"></div>
  <Container>
    <div class="mx-auto max-w-[840px]">
      <div class="space-y-10">
        {brandRows.map((brand, index) => (
          <div class="mx-auto grid max-w-[620px] items-center gap-5 md:grid-cols-[148px_1fr] md:gap-[26px]">
            <div class="flex justify-center md:justify-start">
              <Image
                src={brand.logo}
                alt={brand.logoAlt}
                class="max-h-[88px] w-auto max-w-[128px] object-contain"
                widths={[180, 240]}
                sizes="128px"
              />
            </div>
            <div>
              {index === 0 && (
                <h2 class="mb-4 text-left font-heading text-heading-lg font-semibold text-bleu-abysse md:mb-5">
                  Nos marques commerciales
                </h2>
              )}
              <p class="font-body text-[0.74rem] leading-[1.5] text-bleu-abysse/78">{brand.body}</p>
              <a
                href={brand.linkHref}
                class="mt-3 inline-block font-body text-[0.73rem] font-bold leading-[1.35] text-bleu-abysse underline underline-offset-2"
              >
                {brand.linkLabel}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
