---
import {Image} from "astro:assets"
import Container from "../../ui/Container.astro"
import distributionTextureImage from "../../../assets/images/expertise/texture.png"
import {
  distributionCards,
  expertisesDistributionMagazineCover,
} from "../../../data/expertises"
---

<section id="distribution-section" class="relative overflow-hidden text-bleu-abysse">
  <Image
    src={distributionTextureImage}
    alt=""
    class="pointer-events-none absolute left-0 h-[65%] bottom-0 z-0 w-full"
    widths={[768, 1200, 1680, 2200]}
    sizes="100vw"
  />
  <div
    id="plate-pin-wrapper"
    class="relative z-10 flex h-screen items-center justify-center overflow-hidden"
  >
    <div
      id="plate-backdrop"
      class="absolute inset-0 z-0 overflow-hidden"
      style="clip-path: inset(100% 0 0 0);"
    >
    </div>
    <div class="relative z-10 w-[280px] md:w-[504px] 2xl:w-[700px]">
      <Image
        src={expertisesDistributionMagazineCover}
        alt="Assiette gastronomique illustree pour l'activite distribution"
        class="plate-image w-full"
        widths={[560, 900, 1200]}
        sizes="(min-width: 768px) 504px, 280px"
      />
    </div>
  </div>
  <div class="">
    <div
      class="relative z-10 mx-auto w-full max-w-[1680px] px-5 md:px-8 "
    >
      <div class="mx-auto max-w-[949px] text-center">
        <h2
          data-anim="2"
          class="font-display text-[30px] font-black uppercase leading-[0.97] text-[#ac8652] md:text-[40px] md:leading-[44.5px]"
        >
          Une distribution maîtrisée
        </h2>
      </div>
    </div>

    <div
      class="relative w-screen left-1/2 -translate-x-1/2 px-5 pb-14 text-white mt-6 md:pb-[86px]"
    >
      <Container class="max-w-[1680px] px-5 md:px-8">
        <div class="mx-auto max-w-[1120px] text-center">
          <p
            data-anim="2"
            class="mx-auto max-w-[790px] font-heading text-[15px] font-normal leading-[1.46] text-white md:text-[20px]"
          >
            Pour Reunimer, une filière responsable commence par la capacité à
            nourrir son propre territoire. Grâce à une présence stratégique en
            Océan Indien (Réunion, Madagascar, Maurice) et en France
            métropolitaine, le Groupe assure un lien direct, réactif et
            performant entre la ressource et le marché.
          </p>

          <p
            data-anim="2"
            class="mt-7 font-heading text-[18px] font-medium leading-[1.46] text-white md:mt-[38px] md:text-[32px]"
          >
            La promesse de la filiale distribution de Reunimer
          </p>

          <div
            class="mt-10 grid gap-6 md:mt-[34px] md:grid-cols-3 md:gap-[28px] xl:gap-[34px]"
          >
            {
              distributionCards.map((card) => (
                <article data-distribution-card class="text-center">
                  <h3 class="font-heading text-[16px] font-semibold leading-none tracking-[-0.04em] text-white md:text-[20px]">
                    {card.title}
                  </h3> 
                  <div class="mx-auto mt-6 w-full max-w-[280px] overflow-hidden rounded-[10px] border border-white/18 bg-white/10 shadow-[0_18px_30px_rgba(0,0,0,0.24)] md:max-w-none">
                    <div class="relative aspect-square overflow-hidden">
                      <Image
                        src={card.image}
                        alt={card.alt}
                        class:list={[
                          "h-full w-full object-cover",
                          card.imageClass,
                        ]}
                        widths={[480, 720]}
                        sizes="(min-width: 1280px) 320px, (min-width: 768px) 30vw, 280px"
                      />
                    </div>
                  </div>
                  <p class="mx-auto mt-6 max-w-[220px] font-body text-[13px] leading-[1.4] text-white md:max-w-[285px] md:text-[16px]">
                    {card.description}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </Container>
    </div>
  </div>
</section>
