---
import { Image } from 'astro:assets';
import Container from '../../ui/Container.astro';
import {
  distributionCards,
  expertisesDistributionMagazineCover,
} from '../../../data/expertises';
---

<section class="bg-white py-16 text-bleu-abysse md:py-[110px]">
  <Container>
    <div class="grid gap-10 md:grid-cols-[0.85fr_1.15fr] md:items-start md:gap-[68px]">
      <div>
        <h2 class="font-display text-display-lg font-black leading-[1.02] text-bleu-abysse">
          Une distribution active sur tous les circuits
        </h2>
        <p class="mt-6 max-w-[360px] font-heading text-heading-lg leading-[1.46] text-bleu-abysse/88">
          Grande distribution, restauration, maree, circuits specialises et clients professionnels: Reunimer
          construit une reponse commerciale adaptee a chaque usage.
        </p>
        <div class="mt-8 overflow-hidden rounded-[8px] bg-brume-alize/18 shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <Image
            src={expertisesDistributionMagazineCover}
            alt="Univers editorial et commercial Reunimer"
            class="h-[420px] w-full object-cover object-top"
            widths={[720, 1000]}
            sizes="(min-width: 768px) 430px, 100vw"
          />
        </div>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-5">
        {distributionCards.map((card) => (
          <article class="overflow-hidden rounded-[8px] bg-white shadow-[0_20px_48px_rgba(0,0,0,0.08)] ring-1 ring-bleu-abysse/8">
            <div class="relative h-[250px] overflow-hidden bg-brume-alize/20">
              <Image
                src={card.image}
                alt={card.alt}
                class:list={['h-full w-full object-cover', card.imageClass]}
                widths={[480, 720]}
                sizes="(min-width: 768px) 280px, 100vw"
              />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-heading-lg font-semibold text-bleu-abysse">{card.title}</h3>
              <p class="mt-3 font-body text-body-base leading-[1.5] text-bleu-abysse/76">{card.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </Container>
</section>
