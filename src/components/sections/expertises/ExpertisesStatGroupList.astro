---
import type { ExpertiseStatGroup, ExpertiseStatItem } from '../../../types/expertises';

interface Props {
  groups?: ExpertiseStatGroup[];
  items?: ExpertiseStatItem[];
  groupLabelClass?: string;
  groupSpacingClass?: string;
  itemsWrapperClass?: string;
  rowClass?: string;
  valueClass?: string;
  labelClass?: string;
  dividerClass?: string;
  groupLabelAnim?: string;
  valueAnim?: string;
  labelAnim?: string;
}

const {
  groups = [],
  items = [],
  groupLabelClass = 'font-body text-[0.72rem] font-bold uppercase tracking-[0.08em]',
  groupSpacingClass = 'space-y-8',
  itemsWrapperClass = 'mt-3 space-y-4',
  rowClass = 'flex items-end justify-between gap-6',
  valueClass = 'font-display text-[2.25rem] font-black leading-none',
  labelClass = 'max-w-[220px] text-right font-body text-[0.78rem] leading-[1.35]',
  dividerClass = 'border-b pb-3',
  groupLabelAnim,
  valueAnim,
  labelAnim,
} = Astro.props as Props;

const normalizedGroups = groups.length > 0 ? groups : [{ location: '', items }];

function parseStatValue(value: string) {
  const match = value.match(/^([^0-9]*)([0-9]+(?:[.,][0-9]+)?)(.*)$/u);
  if (!match) {
    return null;
  }

  const decimalPart = match[2].match(/[.,](\d+)$/u);

  return {
    prefix: match[1],
    numericValue: Number(match[2].replace(',', '.')),
    suffix: match[3],
    decimalPlaces: decimalPart ? decimalPart[1].length : 0,
  };
}
---

<div class={groupSpacingClass}>
  {normalizedGroups.map((group) => (
    <div>
      {group.location && <p data-anim={groupLabelAnim} class={groupLabelClass}>{group.location}</p>}
      <div class={group.location ? itemsWrapperClass : 'space-y-4'}>
        {group.items.map((item) => {
          const parsedValue = parseStatValue(item.value);

          return (
          <div data-stat-line-wrapper class={dividerClass}>
            <div class={rowClass}>
              <span
                data-anim={parsedValue ? valueAnim : labelAnim}
                data-count-value={parsedValue ? parsedValue.numericValue : undefined}
                data-count-decimals={parsedValue ? parsedValue.decimalPlaces : undefined}
                data-count-prefix={parsedValue ? parsedValue.prefix : undefined}
                data-count-suffix={parsedValue ? parsedValue.suffix : undefined}
                class={valueClass}
              >
                {item.value}
              </span>
              <span data-anim={labelAnim} class={labelClass}>{item.label}</span>
            </div>
            <span data-stat-line class="mt-3 block h-px w-full origin-left bg-current" aria-hidden="true"></span>
          </div>
          );
        })}
      </div>
    </div>
  ))}
</div>
