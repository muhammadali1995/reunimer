---
/**
 * Footer — pixel-perfect match of Figma node 87:1782.
 *
 * Desktop frame: 1440 × 1413px, bg #002C41
 * Content: 78px side padding → 1284px wide
 *
 * Sections (top→bottom):
 *  1. Contact form    pt-67 / pb to divider at y=813
 *  2. Divider         y=813
 *  3. Site plan       y=813→1169  (pt-45 pb-90)
 *  4. Divider         y=1169
 *  5. Brand + social  pt-51 pb-47   (logo y=1220, strip y=1300)
 *  6. Gradient strip  y=1300, h=7
 *  7. Bottom row      pt-39 pb-46   (y=1346→1413)
 */

import { sitePlan, legalLinks, socialLinks } from '../../data/footer';
import logoFooter from '../../assets/logos/reunimer-logo-footer.svg';
import certifications from '../../assets/icons/footer-certifications.svg';

const inputClasses = 'w-full h-[39px] px-[15px] py-[10px] border border-turquoise-ocean rounded-input bg-transparent font-body text-sm leading-[14px] text-turquoise-ocean outline-none transition-shadow placeholder:text-turquoise-ocean focus:shadow-[0_0_0_1px_var(--color-turquoise-ocean)] appearance-none';
const labelClasses = 'font-body text-sm leading-[14px] text-white';
---

<footer class="bg-bleu-abysse text-white" aria-label="Pied de page">
  <div class="max-w-[1284px] mx-auto px-5 sm:px-10 min-[1440px]:px-0">

    <!-- 1. Contact Form -->
    <section class="flex flex-col items-center pt-[67px] pb-[109px]" aria-labelledby="footer-contact-heading">
      <h2
        id="footer-contact-heading"
        class="font-display font-black text-[28px] leading-[1.2] sm:text-4xl lg:text-display-lg lg:leading-[44.5px] uppercase text-center text-white px-4 sm:px-6 lg:px-0 mb-10 sm:mb-[50px] lg:mb-[62px] lg:whitespace-nowrap"
      >
        Contactez-nous
      </h2>

      <form id="contact-form" class="w-[489px] max-w-full flex flex-col gap-[22px]" aria-label="Formulaire de contact" novalidate>
        <!-- Prénom -->
        <div class="flex flex-col gap-3">
          <label for="f-prenom" class={labelClasses}>Prénom</label>
          <input
            id="f-prenom" name="prenom" type="text" placeholder="Tapez ici" required
            class={inputClasses}
          />
        </div>
        <!-- Nom -->
        <div class="flex flex-col gap-3">
          <label for="f-nom" class={labelClasses}>Nom</label>
          <input
            id="f-nom" name="nom" type="text" placeholder="Tapez ici" required
            class={inputClasses}
          />
        </div>
        <!-- Email -->
        <div class="flex flex-col gap-3">
          <label for="f-email" class={labelClasses}>Email</label>
          <input
            id="f-email" name="email" type="email" placeholder="Tapez ici" required
            class={inputClasses}
          />
        </div>
        <!-- Motif -->
        <div class="flex flex-col gap-3">
          <label for="f-motif" class={labelClasses}>Motif</label>
          <div class="relative">
            <select
              id="f-motif" name="motif" required
              class="w-full h-[39px] px-[15px] py-[10px] border border-turquoise-ocean rounded-input bg-transparent font-body text-sm leading-[14px] text-turquoise-ocean outline-none appearance-none cursor-pointer transition-shadow focus:shadow-[0_0_0_1px_var(--color-turquoise-ocean)]"
            >
              <option value="" disabled selected>Choisissez</option>
              <option value="expertises" class="bg-bleu-abysse text-white">Expertises</option>
              <option value="produits" class="bg-bleu-abysse text-white">Produits</option>
              <option value="engagements-rse" class="bg-bleu-abysse text-white">Engagements RSE</option>
              <option value="carrieres" class="bg-bleu-abysse text-white">Carrières</option>
              <option value="autre" class="bg-bleu-abysse text-white">Autre</option>
            </select>
            <svg
              class="pointer-events-none absolute right-[15px] top-1/2 -translate-y-1/2 w-[14px] h-2 text-turquoise-ocean"
              viewBox="0 0 10.5 6.5"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M0.75 0.75L5.25 5.75L9.75 0.75"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
        </div>
        <!-- Message -->
        <div class="flex flex-col gap-3">
          <label for="f-message" class={labelClasses}>Message</label>
          <textarea
            id="f-message" name="message" placeholder="Tapez ici" required
            class={`${inputClasses} h-[91px] py-[14px] resize-y`}
          ></textarea>
        </div>
        <!-- Submit -->
        <button
          type="submit"
          id="contact-submit"
          class="w-full h-[39px] px-[15px] py-[10px] bg-turquoise-ocean border border-transparent rounded-input font-body text-sm leading-[14px] text-white cursor-pointer transition-colors duration-200 hover:bg-white hover:text-bleu-abysse hover:border-turquoise-ocean disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Envoyer
        </button>
        <!-- Feedback -->
        <p id="contact-feedback" class="font-body text-[13px] leading-[1.4] text-center rounded-input px-[14px] py-[10px] hidden" aria-live="polite"></p>
      </form>
    </section>

    <!-- Divider -->
    <div class="h-px bg-white/30" aria-hidden="true"></div>

    <!-- 2. Site Plan -->
    <section class="pt-[45px] pb-[90px] flex flex-col gap-8 lg:flex-row lg:gap-0" aria-labelledby="footer-sitemap-heading">
      <h2
        id="footer-sitemap-heading"
        class="font-heading font-semibold text-xl tracking-[2.4px] uppercase text-white whitespace-nowrap shrink-0 lg:w-[289px] lg:pt-px"
      >
        Plan du site
      </h2>

      <nav class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8 gap-x-6 lg:gap-0 flex-1" aria-label="Plan du site">
        {sitePlan.map((col) => (
          <div>
            {col.links.length > 0 ? (
              <>
                <p class="font-heading font-extrabold text-xs tracking-[1.44px] uppercase text-white mb-5 whitespace-nowrap">
                  {col.title}
                </p>
                <ul class="list-none flex flex-col gap-[15px]">
                  {col.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="font-heading font-semibold text-[10px] tracking-[1.2px] uppercase text-white no-underline whitespace-nowrap transition-colors hover:text-turquoise-ocean"
                      >
                        {link.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={col.href ?? '#'}
                class="block font-heading font-extrabold text-xs tracking-[1.44px] uppercase text-white no-underline mb-5 whitespace-nowrap transition-colors hover:text-turquoise-ocean"
              >
                {col.title}
              </a>
            )}
          </div>
        ))}
      </nav>
    </section>

    <!-- Divider -->
    <div class="h-px bg-white/30" aria-hidden="true"></div>

    <!-- 3. Brand + Social -->
    <div class="flex items-center justify-between pt-[51px] pb-[47px]">
      <a href="/" aria-label="Reunimer — accueil">
        <img
          src={logoFooter.src}
          alt="Reunimer"
          width="199"
          height="33"
          class="block w-[199px] h-[33px]"
        />
      </a>
      <div class="flex items-center gap-[30px]">
        {socialLinks.map((link) => (
          <a href={link.href} class="block w-[27px] h-[27px] transition-opacity hover:opacity-80" aria-label={link.label}>
            <img src={link.icon.src} alt="" width="27" height="27" class="w-full h-full" />
          </a>
        ))}
      </div>
    </div>

    <!-- 4. Gradient strip -->
    <img
      src={certifications.src}
      alt=""
      width="1284"
      height="7"
      class="block w-full h-[7px]"
      aria-hidden="true"
    />

    <!-- 5. Bottom row -->
    <div class="flex flex-col gap-6 pt-[39px] pb-[46px] sm:flex-row sm:flex-wrap sm:items-start sm:gap-x-10 sm:gap-y-8 lg:flex-nowrap lg:gap-0">
      <div class="font-body text-[10px] leading-[14px] text-white lg:w-[289px] lg:shrink-0">
        <p>9 Rue Armagnac, 97420 Le Port, La Réunion</p>
        <p>0262 42 13 82 - info@reunimer.com</p>
      </div>
      <div class="font-body text-[10px] leading-[14px] text-white lg:w-[338px] lg:shrink-0">
        <p>Reunimer Holding SAS au capital de 2 906 383 &euro;</p>
        <p>SIRET : 52831457800014 - RCS : B 528 314 578</p>
      </div>
      <nav class="flex items-center flex-wrap gap-4 lg:flex-1 lg:justify-end" aria-label="Liens légaux">
        {legalLinks.map((link, i) => (
          <>
            <a
              href={link.href}
              class="font-heading font-semibold text-[10px] tracking-[2.2px] uppercase text-white no-underline whitespace-nowrap transition-colors hover:text-turquoise-ocean"
            >
              {link.text}
            </a>
            {i < legalLinks.length - 1 && (
              <span class="block w-px h-5 bg-white/50 shrink-0" aria-hidden="true"></span>
            )}
          </>
        ))}
      </nav>
    </div>

  </div>
</footer>

<script>
  const form     = document.getElementById('contact-form')     as HTMLFormElement;
  const feedback = document.getElementById('contact-feedback') as HTMLParagraphElement;

  const successClasses = ['bg-[rgba(10,151,166,0.15)]', 'text-[#6de3ec]', 'border', 'border-[rgba(10,151,166,0.4)]'];
  const errorClasses = ['bg-[rgba(163,76,38,0.2)]', 'text-[#f4a07a]', 'border', 'border-[rgba(163,76,38,0.4)]'];

  function showFeedback(msg: string, isError: boolean) {
    feedback.textContent = msg;
    feedback.hidden = false;
    feedback.style.cssText = '';
    feedback.classList.remove('hidden', ...successClasses, ...errorClasses);
    feedback.classList.add(...(isError ? errorClasses : successClasses));
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    feedback.hidden = true;

    const invalid = Array.from(form.elements).find(
      (el) => (el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement)
        ? !el.checkValidity()
        : false
    ) as HTMLInputElement | null;

    if (invalid) {
      invalid.focus();
      showFeedback('Veuillez remplir tous les champs obligatoires.', true);
      return;
    }

    const data = Object.fromEntries(new FormData(form));
    console.log('Form data:', data);
    showFeedback('Votre message a bien été envoyé. Nous vous répondrons rapidement.', false);
    form.reset();
  });
</script>
