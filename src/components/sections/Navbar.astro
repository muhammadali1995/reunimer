---
/**
 * Navbar matching Figma "Header" (node 18:272).
 *
 * Figma specs:
 * - Container: 1360px wide, h-[92px], bg-white, px-[26px] py-[28px]
 * - Logo: 199×33px
 * - Nav links: Montserrat SemiBold 12px, tracking 1.44px, uppercase, bleu-abysse, gap-[34px]
 * - Hover: text turquoise-ocean + 4px turquoise underline bar
 * - Dropdown: white bg, w-[269px], px-[20px] py-[17px], gap-[15px]
 * - Search icon: 14×14px, Lang selector: "FR" + chevron
 * - Fixed at top
 */

import { navLinks } from '../../data/navbar';
import logoHeader from '../../assets/logos/reunimer-logo-header.svg';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

const searchIconPath = 'M13.8362 13.0122L10.3572 9.53312C12.3981 7.03708 12.029 3.35942 9.53297 1.31855C7.03725 -0.722317 3.35937 -0.353212 1.31853 2.14282C-0.722306 4.63886 -0.353207 8.31652 2.14279 10.3574C4.29264 12.1152 7.3834 12.1152 9.53324 10.3574L13.0122 13.8364C13.2436 14.0599 13.6127 14.0536 13.8365 13.8222C14.0545 13.5963 14.0545 13.2384 13.8365 13.0124L13.8362 13.0122ZM5.84717 10.5101C3.27194 10.5101 1.18439 8.42253 1.18439 5.84726C1.18439 3.27199 3.27222 1.18468 5.84717 1.18468C8.42212 1.18468 10.5099 3.27227 10.5099 5.84753C10.5069 8.42143 8.4213 10.5074 5.84717 10.5104V10.5101Z';
const chevronPath = 'M0.75 0.75L5.25 5.75L9.75 0.75';
const checkPath = 'M3 8.5L6.5 12L13 4';
const langOptionClasses = 'lang-option w-full flex items-center justify-between px-4 py-2 font-heading font-semibold text-xs tracking-[1.44px] uppercase text-bleu-abysse hover:bg-gris-clair transition-colors cursor-pointer bg-transparent border-none';
const languages = [
  { code: 'fr', label: 'FR', default: true },
  { code: 'en', label: 'EN', default: false },
];
---

<nav
  class="fixed top-11 left-0 right-0 z-50 flex justify-center"
  id="navbar"
>
  <!-- Desktop bar -->
  <div class="bg-white w-full max-w-[1360px] h-[92px] flex items-center justify-between px-4 sm:px-6 lg:px-[26px]">
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Reunimer — Accueil">
      <img
        src={logoHeader.src}
        alt="Reunimer"
        width="199"
        height="33"
        class="h-[33px] w-[199px]"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-8">
      <div class="flex items-center gap-[34px]">
        {navLinks.map((link) => (
          <div class="nav-item group relative flex items-center h-[92px]">
            <a
              href={link.href}
              class:list={[
                'relative font-heading font-semibold text-xs tracking-[1.44px] uppercase whitespace-nowrap transition-colors flex items-center h-full',
                isActive(link.href) ? 'text-turquoise-ocean' : 'text-bleu-abysse',
              ]}
            >
              {link.label}
            </a>
            <span
              class:list={[
                'absolute bottom-0 left-0 w-full h-[4px] bg-turquoise-ocean transition-opacity',
                isActive(link.href) ? 'opacity-100' : 'opacity-0 group-hover:opacity-100',
              ]}
            />

            {link.children && (
              <div class="absolute top-full left-0 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="w-[269px] bg-white px-5 py-[17px] flex flex-col gap-[15px] shadow-[0_12px_30px_rgba(0,0,0,0.08)]">
                  {link.children.map((child, i) => (
                    <>
                      <a
                        href={child.href}
                        class="font-heading font-semibold text-xs tracking-[1.44px] uppercase text-bleu-abysse whitespace-nowrap transition-colors hover:text-turquoise-ocean"
                      >
                        {child.label}
                      </a>
                      {i < link.children!.length - 1 && (
                        <div class="w-full h-px bg-brume-alize" aria-hidden="true" />
                      )}
                    </>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="flex items-center gap-8">
        <!-- Search -->
        <button
          type="button"
          class="shrink-0 text-bleu-abysse hover:text-turquoise-ocean transition-colors cursor-pointer"
          aria-label="Rechercher"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d={searchIconPath} fill="currentColor"/>
          </svg>
        </button>

        <!-- Language -->
        <div class="relative" id="lang-desktop">
          <button
            type="button"
            class="flex items-center gap-1 shrink-0 cursor-pointer bg-transparent border-none p-0"
            id="lang-desktop-btn"
            aria-label="Choisir la langue"
            aria-expanded="false"
          >
            <span class="font-heading font-semibold text-xs tracking-[1.44px] uppercase text-bleu-abysse" id="lang-desktop-label">
              FR
            </span>
            <svg class="w-[10px] h-[5px] text-brume-alize transition-transform duration-200" id="lang-desktop-chevron" viewBox="0 0 10.5 6.5" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d={chevronPath} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            class="absolute top-full right-0 mt-2 w-[120px] bg-white shadow-[0_12px_30px_rgba(0,0,0,0.08)] py-1 opacity-0 invisible transition-all duration-200 z-50 rounded"
            id="lang-desktop-dropdown"
          >
            {languages.map((lang) => (
              <button
                type="button"
                class={langOptionClasses}
                data-lang={lang.code}
              >
                <span>{lang.label}</span>
                <svg class:list={['lang-check w-3.5 h-3.5 text-turquoise-ocean', { hidden: !lang.default }]} viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d={checkPath} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-[6px] cursor-pointer"
      id="mobile-menu-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-[2px] bg-bleu-abysse transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-[2px] bg-bleu-abysse transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-[2px] bg-bleu-abysse transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div
  class="fixed inset-0 z-40 bg-white translate-x-full transition-transform duration-300 ease-in-out lg:hidden"
  id="mobile-menu"
>
  <div class="h-full pt-[92px] px-6 pb-10 flex flex-col gap-[34px] overflow-y-auto w-full">
    <nav class="flex flex-col gap-5" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <div class="flex flex-col gap-3">
          <a
            href={link.href}
            class:list={[
              'font-heading font-semibold text-xs tracking-[1.44px] uppercase block w-full transition-colors no-underline',
              isActive(link.href) ? 'text-turquoise-ocean' : 'text-bleu-abysse hover:text-turquoise-ocean',
            ]}
          >
            {link.label}
          </a>
          {link.children && (
            <div class="mobile-submenu ml-[22px] mt-[7px] flex flex-col gap-[15px] overflow-hidden max-h-0 transition-[max-height] duration-300 pb-3" data-parent={link.label}>
              {link.children.map((child, i) => (
                <>
                  <a
                    href={child.href}
                    class="font-heading font-semibold text-xs tracking-[1.44px] uppercase text-bleu-abysse whitespace-nowrap transition-colors hover:text-turquoise-ocean block w-full leading-[1.15]"
                  >
                    {child.label}
                  </a>
                  {i < link.children!.length - 1 && (
                    <div class="w-full h-px bg-brume-alize" aria-hidden="true" />
                  )}
                </>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <hr class="w-full border-none border-t border-gris-clair" />

    <div class="flex items-center gap-[22px]">
      <button
        type="button"
        class="bg-transparent border-none p-0 text-bleu-abysse cursor-pointer transition-colors inline-flex items-center justify-center hover:text-turquoise-ocean"
        aria-label="Rechercher"
      >
        <svg class="w-5 h-5" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d={searchIconPath} fill="currentColor"/>
        </svg>
      </button>
      <div class="relative" id="lang-mobile">
        <button
          type="button"
          class="inline-flex items-center gap-[7px] font-heading font-semibold text-xs tracking-[1.44px] uppercase text-bleu-abysse bg-transparent border-none p-0 cursor-pointer"
          id="lang-mobile-btn"
          aria-label="Choisir la langue"
          aria-expanded="false"
        >
          <span id="lang-mobile-label">FR</span>
          <svg class="w-[10px] h-[5px] transition-transform duration-200" id="lang-mobile-chevron" viewBox="0 0 10.5 6.5" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d={chevronPath} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div
          class="absolute bottom-full left-0 mb-2 w-[120px] bg-white shadow-[0_12px_30px_rgba(0,0,0,0.08)] py-1 opacity-0 invisible transition-all duration-200 z-50 rounded"
          id="lang-mobile-dropdown"
        >
          {languages.map((lang) => (
            <button
              type="button"
              class={langOptionClasses}
              data-lang={lang.code}
            >
              <span>{lang.label}</span>
              <svg class:list={['lang-check w-3.5 h-3.5 text-turquoise-ocean', { hidden: !lang.default }]} viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d={checkPath} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Spacer to push content below fixed navbar -->
<div class="h-[92px]"></div>

<script>
  // --- Mobile menu ---
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');

    if (open) {
      menu?.classList.remove('translate-x-full');
      menu?.classList.add('translate-x-0');
      bar1?.classList.add('rotate-45', 'translate-y-[4px]');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-[4px]');
      document.body.style.overflow = 'hidden';
    } else {
      menu?.classList.add('translate-x-full');
      menu?.classList.remove('translate-x-0');
      bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-[4px]');
      document.body.style.overflow = '';
    }
  });

  // --- Mobile accordion submenus ---
  document.querySelectorAll('#mobile-menu a[href]').forEach((link) => {
    const parent = link.nextElementSibling;
    if (parent?.classList.contains('mobile-submenu')) {
      link.addEventListener('click', (e) => {
        if ((parent as HTMLElement).style.maxHeight) {
          (parent as HTMLElement).style.maxHeight = '';
        } else {
          e.preventDefault();
          (parent as HTMLElement).style.maxHeight = parent.scrollHeight + 'px';
        }
      });
    }
  });

  // --- Language dropdown ---
  function initLangDropdown(id: string) {
    const wrapper = document.getElementById(id);
    const btnEl = document.getElementById(`${id}-btn`);
    const dropdown = document.getElementById(`${id}-dropdown`);
    const chevron = document.getElementById(`${id}-chevron`);
    const label = document.getElementById(`${id}-label`);
    if (!wrapper || !btnEl || !dropdown || !label) return;

    let langOpen = false;

    function toggle() {
      langOpen = !langOpen;
      btnEl!.setAttribute('aria-expanded', String(langOpen));
      if (langOpen) {
        dropdown!.classList.remove('opacity-0', 'invisible');
        dropdown!.classList.add('opacity-100', 'visible');
        chevron?.classList.add('rotate-180');
      } else {
        dropdown!.classList.add('opacity-0', 'invisible');
        dropdown!.classList.remove('opacity-100', 'visible');
        chevron?.classList.remove('rotate-180');
      }
    }

    function close() {
      if (!langOpen) return;
      langOpen = false;
      btnEl!.setAttribute('aria-expanded', 'false');
      dropdown!.classList.add('opacity-0', 'invisible');
      dropdown!.classList.remove('opacity-100', 'visible');
      chevron?.classList.remove('rotate-180');
    }

    btnEl.addEventListener('click', (e) => {
      e.stopPropagation();
      toggle();
    });

    dropdown.querySelectorAll('.lang-option').forEach((opt) => {
      opt.addEventListener('click', () => {
        const lang = (opt as HTMLElement).dataset.lang?.toUpperCase() || 'FR';
        label.textContent = lang;

        // Update checks in this dropdown
        dropdown!.querySelectorAll('.lang-check').forEach((check) => check.classList.add('hidden'));
        opt.querySelector('.lang-check')?.classList.remove('hidden');

        // Sync the other dropdown
        const otherId = id === 'lang-desktop' ? 'lang-mobile' : 'lang-desktop';
        const otherLabel = document.getElementById(`${otherId}-label`);
        if (otherLabel) otherLabel.textContent = lang;
        const otherDropdown = document.getElementById(`${otherId}-dropdown`);
        otherDropdown?.querySelectorAll('.lang-option').forEach((o) => {
          const check = o.querySelector('.lang-check');
          if ((o as HTMLElement).dataset.lang === (opt as HTMLElement).dataset.lang) {
            check?.classList.remove('hidden');
          } else {
            check?.classList.add('hidden');
          }
        });

        close();
      });
    });

    document.addEventListener('click', (e) => {
      if (!wrapper.contains(e.target as Node)) close();
    });
  }

  initLangDropdown('lang-desktop');
  initLangDropdown('lang-mobile');

  // --- Desktop: hover opens dropdown, also change link text color ---
  document.querySelectorAll('.nav-item').forEach((item) => {
    const link = item.querySelector('a');
    const dropdown = item.querySelector('[class*="group-hover"]');
    if (!dropdown) return;

    item.addEventListener('mouseenter', () => {
      link?.classList.add('text-turquoise-ocean');
      link?.classList.remove('text-bleu-abysse');
    });
    item.addEventListener('mouseleave', () => {
      if (!link?.getAttribute('class')?.includes('active-link')) {
        const isActive = link?.querySelector('.opacity-100');
        if (!isActive) {
          link?.classList.remove('text-turquoise-ocean');
          link?.classList.add('text-bleu-abysse');
        }
      }
    });
  });
</script>
