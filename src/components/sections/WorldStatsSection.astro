---
/**
 * "World Stats & Client Portfolio" Section (Phase 8)
 *
 * Figma nodes: 729:3157–729:3196 (y=8003–9338)
 * Two visual areas:
 *   1. Dark bg (bleu-abysse): "Une portée mondiale" + 71% stat + continent bar chart
 *   2. White bg: "Un portefeuille client équilibré" + donut chart + legend
 *
 * Continent chart: 729:3184 (x=89, y=8132, w=582, h=213)
 * Donut chart: 729:3194 (x=335, y=8796, w=283, h=305) — built with CSS conic-gradient
 * Legend: 729:3186 (x=690, y=8800, w=420, h=322) — 7 rows
 */

import { continents, portfolio, colorHex } from '../../data/groupe';

interface Props {
  id?: string;
}

const { id = 'stats-monde' } = Astro.props;

function parseCountValue(value: string) {
  const match = value.match(/^([^0-9]*)([0-9]+(?:[.,][0-9]+)?)(.*)$/u);
  if (!match) {
    return { prefix: '', numericValue: 0, suffix: value, decimals: 0 };
  }

  const rawNumber = match[2];
  const fractionalPart = rawNumber.includes('.') ? rawNumber.split('.')[1] : rawNumber.split(',')[1];

  return {
    prefix: match[1],
    numericValue: Number(rawNumber.replace(',', '.')),
    suffix: match[3],
    decimals: fractionalPart ? fractionalPart.length : 0,
  };
}

/* Build conic-gradient stops for the donut chart */
function buildConicGradient() {
  let angle = 0;
  const stops: string[] = [];
  for (const item of portfolio) {
    const deg = (item.pct / 100) * 360;
    const hex = colorHex[item.color];
    stops.push(`${hex} ${angle}deg ${angle + deg}deg`);
    angle += deg;
  }
  return `conic-gradient(${stops.join(', ')})`;
}

const conicGradient = buildConicGradient();
const worldSalesStat = parseCountValue('71%');
const donutCenterStat = parseCountValue('106,1 M€');
---

<section id={id} class="scroll-mt-[135px]">
  <!-- Part 1: World Stats (dark bg, continues from Implantations) -->
  <div class="bg-bleu-abysse pt-12 md:pt-16 lg:pt-20 pb-16 md:pb-24 lg:pb-[120px]">
    <div class="mx-auto w-full max-w-[1284px] px-5 md:px-10 lg:px-0">

      <!-- Top row: title (left) + 71% stat (right) -->
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10 lg:gap-16">

        <!-- Left: title -->
        <div data-anim="1" class="max-w-[365px]">
          <p class="font-heading text-[24px] md:text-[32px] leading-[1.36] text-white">
            <span class="font-bold">Une portée mondiale </span><br />
            <span class="font-medium">sur les 5 continents</span>
          </p>
        </div>

        <!-- Right: 71% stat -->
        <div data-anim="1" class="lg:max-w-[456px]">
          <p
            data-anim="4"
            data-count-value={worldSalesStat.numericValue}
            data-count-prefix={worldSalesStat.prefix}
            data-count-suffix={worldSalesStat.suffix}
            data-count-decimals={worldSalesStat.decimals}
            class="font-display font-extrabold text-[32px] md:text-[48px] lg:text-[61px] lg:leading-[68px] uppercase text-white"
          >
            71%
          </p>
          <p class="mt-1 font-body font-normal text-sm md:text-body-base text-white leading-[1.4]">
            de produits vendus en France<br />(Métropole et Réunion)
          </p>
        </div>
      </div>

      <!-- Continent distribution chart -->
      <div class="mt-10 md:mt-12 lg:mt-16 max-w-[780px]">
        <div class="flex flex-col gap-3 md:gap-4">
          {continents.map((c) => {
            const parsedPct = parseCountValue(`${c.pct}%`);

            return (
            <div class="flex items-center gap-2 md:gap-3">
              <p data-anim="1" class="font-body font-bold text-[13px] md:text-[15px] lg:text-[18px] leading-[1.4] text-white text-right w-[120px] md:w-[170px] lg:w-[230px] shrink-0">
                {c.name}
              </p>
              <div class="flex items-center gap-2 md:gap-3 flex-1 min-w-0">
                <div
                  data-chart-bar
                  data-bar-target={`${(c.pct / 36) * 100}%`}
                  class="h-[22px] md:h-[28px] lg:h-[32px] bg-turquoise-ocean rounded-[3px]"
                  style="width: 0%;"
                />
                <p
                  data-bar-count
                  data-count-value={parsedPct.numericValue}
                  data-count-prefix={parsedPct.prefix}
                  data-count-suffix={parsedPct.suffix}
                  data-count-decimals={parsedPct.decimals}
                  class="font-body font-normal text-[13px] md:text-[15px] lg:text-[18px] leading-[1.4] text-white shrink-0"
                >
                  {c.pct}%
                </p>
              </div>
            </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <!-- Part 2: Client Portfolio (white bg) -->
  <div class="bg-white py-16 md:py-24 lg:py-[120px]">
    <div class="mx-auto w-full max-w-[1284px] px-5 md:px-10 lg:px-0">

      <!-- Chart + Legend row -->
      <div class="flex flex-col lg:flex-row items-center lg:items-start gap-10 lg:gap-16">

        <!-- Donut chart (CSS conic-gradient) — perfect circle, thin ring -->
        <div
          data-donut-chart
          data-donut-segments={JSON.stringify(portfolio.map((item) => ({ pct: item.pct, color: colorHex[item.color] })))}
          class="relative w-[240px] h-[240px] md:w-[283px] md:h-[283px] shrink-0 lg:ml-[150px]"
        >
          <div
            class="w-full h-full rounded-full"
            style={`background: ${conicGradient};`}
          />
          <!-- Inner white circle (donut hole) — ~70% diameter for thin ring -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-[68%] h-[68%] rounded-full bg-white flex items-center justify-center">
              <p
                data-anim="4"
                data-count-value={donutCenterStat.numericValue}
                data-count-prefix={donutCenterStat.prefix}
                data-count-suffix={donutCenterStat.suffix}
                data-count-decimals={donutCenterStat.decimals}
                class="font-display font-extrabold text-[20px] md:text-[24px] text-bleu-abysse uppercase leading-none"
              >
                106,1 M€
              </p>
            </div>
          </div>
        </div>

        <!-- Title + Legend -->
        <div class="w-full max-w-[420px]">
          <!-- Title: Montserrat SemiBold 20px + ExtraBold 20px, bleu-abysse -->
          <p data-anim="1" class="font-heading text-[18px] md:text-[20px] text-bleu-abysse tracking-[-1px] mb-6 lg:mb-8">
            <span class="font-semibold">Un portefeuille client équilibré</span><br />
            <span class="font-extrabold">(% sur volume total)</span>
          </p>

          <!-- Legend rows: label 14px Montserrat SemiBold + pct 20px Zalando ExtraBold -->
          <div class="flex flex-col gap-[5px] w-full max-w-[353px]">
            {portfolio.map((item) => {
              const parsedPct = parseCountValue(`${item.pct}%`);

              return (
              <div data-legend-row class="relative flex items-baseline justify-between pb-[5px]">
                <p
                  data-anim="1"
                  class="font-heading font-semibold text-[14px] leading-[1.4]"
                  style={`color: ${colorHex[item.color]};`}
                >
                  {item.label}
                </p>
                <p
                  data-anim="4"
                  data-count-value={parsedPct.numericValue}
                  data-count-prefix={parsedPct.prefix}
                  data-count-suffix={parsedPct.suffix}
                  data-count-decimals={parsedPct.decimals}
                  class="font-display font-extrabold text-[16px] md:text-[20px] leading-[1.2] uppercase text-right shrink-0 ml-4"
                  style={`color: ${colorHex[item.color]};`}
                >
                  {item.pct}%
                </p>
                <span data-legend-line class="absolute left-0 right-0 bottom-0 h-px bg-gray-200 origin-left" aria-hidden="true" />
              </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
