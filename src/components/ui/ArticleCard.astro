---
/**
 * Article/News card matching Figma "Petite-photo-actu" and "Grande-Photo-Actu" patterns.
 *
 * Layouts:
 * - vertical (default): image on top, tag overlay, meta below
 * - horizontal: image left, meta right (featured small articles)
 *
 * Small card variant:
 * - Image (overflow hidden, object-cover)
 * - Tag badge (positioned top-left)
 * - Date: Inter Medium 12px, brume-alize, leading ~101%
 * - Title: Montserrat Bold 20px, leading-none, bleu-abysse
 *
 * Large card variant:
 * - Same structure, bigger image area
 * - Title: Montserrat Bold 32px
 */

import { Image } from 'astro:assets';
import Tag from './Tag.astro';

interface Props {
  title: string;
  date: string;
  tag: string;
  tagColor?: 'bleu-abysse' | 'turquoise-ocean' | 'sable-corail';
  image?: ImageMetadata;
  imageAlt?: string;
  href: string;
  size?: 'sm' | 'lg';
  layout?: 'vertical' | 'horizontal';
  description?: string;
  class?: string;
}

const {
  title,
  date,
  tag,
  tagColor = 'bleu-abysse',
  image,
  imageAlt = '',
  href,
  size = 'sm',
  layout = 'vertical',
  description,
  class: className = '',
} = Astro.props;

const isLarge = size === 'lg';
const isHorizontal = layout === 'horizontal';
---

{isHorizontal ? (
  <a href={href} class:list={['group flex flex-row gap-5', className]}>
    <div class="relative overflow-hidden w-[223px] h-[154px] flex-shrink-0" data-ken-burns>
      {image ? (
        <div class="absolute inset-0 w-full h-full transition-transform duration-500 group-hover:scale-105">
          <Image
            src={image}
            alt={imageAlt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="absolute inset-0 bg-[#D9D9D9]" />
      )}
    </div>
    <div class="flex flex-col items-start justify-start pt-1">
      <Tag color={tagColor}>{tag}</Tag>
      <time class="mt-2 font-body font-medium text-label-sm leading-none text-brume-alize uppercase">
        {date}
      </time>
      <h3 class="mt-[6px] font-heading font-bold text-base md:text-heading-lg leading-none text-bleu-abysse group-hover:text-turquoise-ocean transition-colors">
        {title}
      </h3>
    </div>
  </a>
) : (
  <a href={href} class:list={['group block', className]}>
    <!-- Image -->
    <div class:list={['relative overflow-hidden', isLarge ? 'aspect-[710/498]' : 'aspect-[364/318]']} data-ken-burns>
      {image ? (
        <div class="absolute inset-0 w-full h-full transition-transform duration-500 group-hover:scale-105">
          <Image
            src={image}
            alt={imageAlt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="absolute inset-0 bg-[#D9D9D9]" />
      )}
      <div class="absolute top-[19px] left-[14px]">
        <Tag color={tagColor}>{tag}</Tag>
      </div>
    </div>

    <!-- Meta -->
    <div class="mt-3">
      <time class="font-body font-medium text-label-sm leading-none text-brume-alize uppercase">
        {date}
      </time>
      <h3
        class:list={[
          'mt-2 font-heading font-bold text-bleu-abysse group-hover:text-turquoise-ocean transition-colors',
          isLarge ? 'text-xl md:text-[32px] md:leading-normal' : 'text-base md:text-heading-lg md:leading-none',
        ]}
      >
        {title}
      </h3>
      {description && (
        <p class="mt-2 font-body text-body-base leading-[1.4] text-bleu-abysse">
          {description}
        </p>
      )}
    </div>
  </a>
)}
