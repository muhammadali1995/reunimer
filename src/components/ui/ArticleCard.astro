---
/**
 * Article/News card matching Figma "Petite-photo-actu" and "Grande-Photo-Actu" patterns.
 *
 * Small card variant:
 * - Image (overflow hidden, object-cover)
 * - Tag badge (positioned top-left)
 * - Date: Inter Medium 12px, brume-alize, leading ~101%
 * - Title: Montserrat Bold 20px, leading-none, bleu-abysse
 *
 * Large card variant:
 * - Same structure, bigger image area
 * - Title: Montserrat Bold 32px
 */

import Tag from './Tag.astro';

interface Props {
  title: string;
  date: string;
  tag: string;
  tagColor?: 'bleu-abysse' | 'turquoise-ocean' | 'sable-corail';
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  size?: 'sm' | 'lg';
  class?: string;
}

const {
  title,
  date,
  tag,
  tagColor = 'bleu-abysse',
  imageSrc,
  imageAlt = '',
  href = '#',
  size = 'sm',
  class: className = '',
} = Astro.props;

const isLarge = size === 'lg';
---

<a href={href} class:list={['group block', className]}>
  <!-- Image -->
  <div class:list={['relative overflow-hidden', isLarge ? 'aspect-[4/3]' : 'aspect-[4/3]']}>
    {imageSrc && (
      <img
        src={imageSrc}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    )}
    <div class="absolute top-3 left-3">
      <Tag color={tagColor}>{tag}</Tag>
    </div>
  </div>

  <!-- Meta -->
  <div class="mt-3">
    <time class="font-body font-medium text-xs leading-none text-brume-alize uppercase">
      {date}
    </time>
    <h3
      class:list={[
        'mt-2 font-heading font-bold text-bleu-abysse group-hover:text-turquoise-ocean transition-colors',
        isLarge ? 'text-xl md:text-[32px] md:leading-normal' : 'text-base md:text-xl md:leading-none',
      ]}
    >
      {title}
    </h3>
  </div>
</a>
