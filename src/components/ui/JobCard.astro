---
/**
 * Job listing accordion card for the Carrières page.
 *
 * Renders a colored accordion panel with job title, mission/benefit content,
 * and an apply CTA. Used inside the #job-accordion container.
 */

import Button from './Button.astro';

interface Props {
  title: string;
  bgColor: string;
  missionText: string;
  benefitTitle: string;
  benefitText: string;
  extraTitle: string;
  extraText: string;
  applyHref?: string;
  defaultExpanded?: boolean;
  index: number;
}

const {
  title,
  bgColor,
  missionText,
  benefitTitle,
  benefitText,
  extraTitle,
  extraText,
  applyHref = '#footer-contact-heading',
  defaultExpanded = false,
  index,
} = Astro.props;

const panelId = `job-panel-${index}`;
const headingId = `job-heading-${index}`;
---

<div class:list={['job-card overflow-hidden', bgColor]} data-job={index} data-expanded={String(defaultExpanded)}>
  <!-- Header bar (always visible) -->
  <button
    type="button"
    class:list={[
      'w-full flex items-center justify-between px-6 md:px-16 lg:px-[101px] cursor-pointer text-left',
      defaultExpanded ? 'py-8 md:py-10 lg:py-[49px]' : 'py-8 md:py-10 lg:py-[48px]',
    ]}
    aria-expanded={String(defaultExpanded)}
    aria-controls={panelId}
  >
    <h3 id={headingId} class="font-heading font-semibold text-base md:text-lg lg:text-xl text-white pr-4">
      {title}
    </h3>
    <svg
      class:list={[
        'job-chevron w-6 h-3.5 md:w-[34px] md:h-[20px] shrink-0 text-white transition-transform duration-300',
        defaultExpanded && 'rotate-180',
      ]}
      viewBox="0 0 34 20"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M2 2L17 18L32 2" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Expandable content -->
  <div
    id={panelId}
    role="region"
    aria-labelledby={headingId}
    class="job-content transition-[max-height] duration-300 ease-in-out overflow-hidden"
    style={defaultExpanded ? 'max-height: 1000px;' : 'max-height: 0;'}
  >
    <!-- Divider -->
    <div class="mx-6 md:mx-16 lg:mx-[101px] h-px bg-white/40" aria-hidden="true"></div>

    <!-- Two-column content -->
    <div class="px-6 md:px-16 lg:px-[101px] pt-6 pb-8 md:pt-8 md:pb-12 lg:pt-[24px] lg:pb-[69px] grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 lg:gap-[65px]">
      <div>
        <p class="font-body font-bold text-sm md:text-base text-white mb-2">
          Votre Mission&nbsp;:
        </p>
        <p class="font-body font-normal text-sm md:text-base leading-[1.4] text-white">
          {missionText}
        </p>
      </div>
      <div>
        <p class="font-body font-bold text-sm md:text-base text-white mb-1">
          {benefitTitle}
        </p>
        <p class="font-body font-normal text-sm md:text-base leading-[1.4] text-white mb-4">
          {benefitText}
        </p>
        <p class="font-body font-bold text-sm md:text-base text-white mb-1">
          {extraTitle}
        </p>
        <p class="font-body font-normal text-sm md:text-base leading-[1.4] text-white">
          {extraText}
        </p>
      </div>
    </div>

    <!-- Apply button -->
    <div class="px-6 md:px-16 lg:px-[101px] pb-8 md:pb-12 lg:pb-[69px]">
      <Button variant="outline-light" href={applyHref}>Postuler à l'offre</Button>
    </div>
  </div>
</div>
