---
/**
 * Button component matching Figma "Bouton" patterns.
 *
 * Variants from Figma:
 * - outline-dark:  border 1px bleu-abysse, text bleu-abysse, on light backgrounds
 *                  px-[22px] py-[19px], rounded-[3px], Montserrat SemiBold 12px, tracking 1.44px
 * - outline-light: border 1px white, text white, on dark/colored backgrounds
 *                  px-[18px] py-[16px], same typography
 * - primary:       bg turquoise-ocean, text white, full-width form submit
 *                  px-[15px] py-[10px], rounded-[5px], Inter Regular 14px
 * - pill-primary:  bg turquoise-ocean, text white, rounded pill CTA
 *                  px-[22px] py-[18px], rounded-[47px], Montserrat SemiBold 12px
 * - pill-light:    bg white, text bleu-abysse, rounded pill CTA (hover state)
 *                  px-[22px] py-[18px], rounded-[47px], same typography
 */

interface Props {
  variant?: 'outline-dark' | 'outline-light' | 'primary' | 'pill-primary' | 'pill-light';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  hideArrow?: boolean;
}

const {
  variant = 'outline-dark',
  href,
  type = 'button',
  class: className = '',
  hideArrow = false,
} = Astro.props;

const Tag = href ? 'a' : 'button';

const base = 'inline-flex items-center gap-3.5 font-heading font-semibold uppercase cursor-pointer transition-opacity hover:opacity-80';

const variants = {
  'outline-dark': `border border-bleu-abysse rounded-[3px] px-[22px] py-[19px] text-bleu-abysse text-xs tracking-[1.44px]`,
  'outline-light': `border border-white rounded-[3px] px-[18px] py-[16px] text-white text-xs tracking-[1.44px]`,
  'primary': `bg-turquoise-ocean rounded-[5px] px-[15px] py-2.5 text-white font-body font-normal text-sm justify-center w-full`,
  'pill-primary': `bg-turquoise-ocean rounded-[47px] px-[22px] py-[18px] text-white text-xs tracking-[1.44px] no-underline`,
  'pill-light': `bg-white rounded-[47px] px-[22px] py-[18px] text-bleu-abysse text-xs tracking-[1.44px] no-underline hover:bg-gris-clair`,
};

const classes = [base, variants[variant], className].join(' ');
---

<Tag
  class={classes}
  {...href ? { href } : { type }}
>
  <slot />
  {!hideArrow && variant !== 'primary' && (
    <svg
      class="w-2 h-3.5 shrink-0"
      viewBox="0 0 10.5 16.5"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d="M1.25 15.25L9.25 8.25L1.25 1.25"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )}
</Tag>
