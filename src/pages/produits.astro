---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import heroImage from '../assets/images/produits/hero-produits.png';

// Product images — replace placeholders with real Figma exports
import poissonsPelagiquesImg from '../assets/images/produits/poissons-pelagiques.png';
import langousteMadagascarImg from '../assets/images/produits/langouste-madagascar.png';
import crabeMadagascarImg from '../assets/images/produits/crabe-madagascar.png';
import seicheBoulogneImg from '../assets/images/produits/seiche-boulogne.png';
import sardineBoulogneImg from '../assets/images/produits/sardine-boulogne.png';
import poulpeMadagascarImg from '../assets/images/produits/poulpe-madagascar.png';
import legineTaafImg from '../assets/images/produits/legine-taaf.png';
import poissonsDemerseauxImg from '../assets/images/produits/poissons-demersaux.png';
import produitsTraiteurImg from '../assets/images/produits/produits-traiteur.png';

const products = [
  { name: 'Poissons pélagiques',  origin: "de l'Océan Indien",          image: poissonsPelagiquesImg,  alt: 'Thon albacore frais tranché — poissons pélagiques de l\'Océan Indien' },
  { name: 'Langouste',            origin: 'de Madagascar',              image: langousteMadagascarImg, alt: 'Langouste tropicale congelée — langouste de Madagascar' },
  { name: 'Crabe',                origin: 'de Madagascar',              image: crabeMadagascarImg,     alt: 'Crabe préparé — crabe de Madagascar' },
  { name: 'Seiche',               origin: 'de Boulogne-sur-Mer',        image: seicheBoulogneImg,      alt: 'Seiche fraîche cuisinée — seiche de Boulogne-sur-Mer' },
  { name: 'Sardine',              origin: 'de Boulogne-sur-Mer',        image: sardineBoulogneImg,     alt: 'Sardines fraîches — sardine de Boulogne-sur-Mer' },
  { name: 'Poulpe',               origin: 'de Madagascar',              image: poulpeMadagascarImg,    alt: 'Poulpe (zourite) cuisiné — poulpe de Madagascar' },
  { name: 'Légine',               origin: 'des TAAF',                   image: legineTaafImg,          alt: 'Filet de légine — légine des TAAF' },
  { name: 'Poissons démersaux',   origin: 'de Madagascar',              image: poissonsDemerseauxImg,  alt: 'Filet de poisson démersal — poissons démersaux de Madagascar' },
  { name: 'Produits traiteur',    origin: "de l'Île de la Réunion",     image: produitsTraiteurImg,    alt: 'Produits traiteur préparés — produits traiteur de l\'Île de la Réunion' },
];
---

<PageLayout
  title="Produits — Reunimer"
  description="Découvrez l'offre Reunimer : poissons pélagiques, langouste, crabe, poulpe, légine et produits traiteur, directement de l'océan Indien à votre assiette."
>
  <!-- Hero Section -->
  <section class="relative -mt-[92px]">
    <!-- Hero image area -->
    <div class="relative h-[400px] sm:h-[500px] md:h-[700px] lg:h-[1100px] overflow-hidden">
      <Image
        src={heroImage}
        alt="L'inspiration qui a du goût — une convive savourant un plat de poisson dans un restaurant"
        class="w-full h-full object-cover"
        widths={[375, 768, 1024, 1440]}
        sizes="100vw"
      />
      <!-- Gradient fade to white -->
      <div class="absolute bottom-0 left-0 right-0 h-[100px] md:h-[200px] lg:h-[300px] bg-gradient-to-b from-transparent to-white pointer-events-none"></div>

      <!-- Hero title overlay — centered on mobile, Figma-positioned on desktop -->
      <div class="absolute inset-0 flex items-center justify-center px-6 lg:block">
        <h1 class="font-display font-black text-[28px] leading-[1.05] sm:text-[36px] md:text-[48px] lg:text-[64px] lg:leading-[67px] uppercase text-white text-center lg:text-left lg:absolute lg:top-[320px] lg:left-[calc(50%-69px)] lg:w-[637px] drop-shadow-[0_4px_16.2px_rgba(0,0,0,0.51)]">
          L'inspiration<br />qui a du go&ucirc;t
        </h1>
      </div>
    </div>

    <!-- Intro text on white background -->
    <div class="bg-white pt-6 pb-8 md:pt-8 md:pb-10 lg:pt-[42px] lg:pb-[50px] text-center">
      <Container>
        <h2 class="font-display font-black text-[24px] leading-[1.1] md:text-[32px] lg:text-[40px] lg:leading-[44.5px] uppercase text-bleu-abysse">
          D&eacute;couvrez notre offre
        </h2>
        <p class="mt-6 md:mt-8 lg:mt-[42px] font-heading font-normal text-base leading-relaxed md:text-lg md:leading-[1.461] lg:text-xl text-bleu-abysse mx-auto max-w-[589px]">
          Issus exclusivement de nos propres filiales, nos produits garantissent une tra&ccedil;abilit&eacute; totale.
          Voici l'offre de Reunimer avec le meilleur de l'Oc&eacute;an Indien et de la Manche. Directement de la mer &agrave; votre assiette.
        </p>

        <!-- Scroll arrow -->
        <a
          href="#catalogue"
          class="inline-block mt-6 md:mt-8 lg:mt-[45px] transition-transform hover:translate-y-1"
          aria-label="Voir le catalogue produits"
        >
          <svg
            class="w-[30px] h-[14px] md:w-[40px] md:h-[18px] text-turquoise-ocean"
            viewBox="0 0 48 26"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M4 4L24 22L44 4" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </Container>
    </div>
  </section>

  <!-- Product Catalogue -->
  <section id="catalogue" class="bg-white pb-16 md:pb-20 lg:pb-[100px]">
    <div class="mx-auto max-w-[1082px] px-5 md:px-10 lg:px-0 flex flex-col gap-6 md:gap-7 lg:gap-8">
      {products.map((product) => (
        <ProductCard
          name={product.name}
          origin={product.origin}
          imageSrc={product.image}
          imageAlt={product.alt}
        />
      ))}
    </div>
  </section>

  <!-- CTA Button -->
  <div class="bg-white pb-16 md:pb-20 lg:pb-[130px] flex justify-center">
    <a
      href="#footer-contact-heading"
      class="inline-flex items-center gap-3.5 bg-turquoise-ocean rounded-[47px] px-[22px] py-[18px] font-heading font-semibold text-xs tracking-[1.44px] uppercase text-white no-underline transition-opacity hover:opacity-80"
    >
      Contactez-nous pour en savoir plus
      <svg
        class="w-2 h-3.5 shrink-0"
        viewBox="0 0 10.5 16.5"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M1.25 15.25L9.25 8.25L1.25 1.25"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
</PageLayout>
