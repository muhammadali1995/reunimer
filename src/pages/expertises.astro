---
import { Image } from "astro:assets";
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import heroImage from "../assets/images/expertise/hero.png";
import heroImage2 from "../assets/images/expertise/hero-2.png";
import fishIllustration from "../assets/images/expertise/fish-illustration.png";
import pecheMadagascarImage from "../assets/images/expertise/peche-madagascar.png";
import thonSeulImage from "../assets/images/expertise/thon-seul.png";
import transformation1Image from "../assets/images/expertise/transformation-1.png";
import transformation2Image from "../assets/images/expertise/transformation-2.png";
import smokeImage from "../assets/images/expertise/smoke.png";
import magazineCoverImage from "../assets/images/expertise/magazine-cover.png";
import distriApproImage from "../assets/images/expertise/distri-approvisionnement.png";
import distriExpertiseImage from "../assets/images/expertise/distri-expertise.png";
import distriServiceImage from "../assets/images/expertise/distri-service.png";
import supportBgImage from "../assets/images/expertise/support-bg.png";
import rhBgImage from "../assets/images/expertise/rh-background.png";
import seafoodKorailLogo from "../assets/images/brands/seafood-korail.png";
import redPremierLogo from "../assets/images/brands/red-premier.jpg";
import lecrol from "../assets/images/brands/lecrol.png";
---

<PageLayout
  title="Nos Expertises — Reunimer"
  description="Découvrez les expertises du groupe Reunimer : pêche, production, distribution, supports et ressources humaines."
>
  <!-- Blended ocean background wrapper -->
  <div class="relative overflow-x-hidden">
    <!-- Bottom layer: underwater ocean -->
    <Image
      src={heroImage2}
      alt="Fond sous-marin — l'expertise océanique de Reunimer"
      class="absolute inset-0 w-full h-full object-cover"
      widths={[375, 768, 1024, 1440]}
      sizes="100vw"
    />
    <!-- Top layer: boat on surface — fades to reveal underwater via CSS mask -->
    <Image
      src={heroImage}
      alt="Expertise Reunimer : une vue de l'océan, symbole de notre savoir-faire maritime"
      class="absolute inset-0 w-full h-full object-cover object-top [mask-image:linear-gradient(to_bottom,black_30%,transparent_70%)] [-webkit-mask-image:linear-gradient(to_bottom,black_30%,transparent_70%)]"
      widths={[375, 768, 1024, 1440]}
      sizes="100vw"
    />

    <!-- Hero Section -->
    <section
      class="-mt-[92px] relative z-20 h-[400px] sm:h-[500px] md:h-[600px] lg:h-[700px] overflow-hidden"
    >
      <!-- Dark overlay for text readability -->
      <div class="absolute inset-0 bg-black/30"></div>

      <!-- Title overlay -->
      <div
        class="absolute inset-0 flex items-end pb-16 md:pb-20 lg:pb-0 lg:items-start lg:pt-[250px]"
      >
        <Container>
          <h1
            class="font-display font-black text-[28px] leading-[34px] sm:text-[36px] sm:leading-[40px] md:text-[40px] md:leading-[44.5px] uppercase text-white"
          >
            noS expertiseS
          </h1>
        </Container>
      </div>
    </section>

    <!-- Filières Bar -->
    <div class="relative z-20 flex items-end max-w-[1198px] mx-auto w-[calc(100%-40px)] md:w-[calc(100%-80px)] lg:w-full">
      <div
        class="flex-1 flex items-center justify-center bg-terre-laterite h-[36px] md:h-[42px] lg:h-[47px]"
      >
        <span
          class="font-heading font-semibold text-[8px] md:text-[10px] lg:text-xs text-white uppercase tracking-[1.44px]"
          >Pêche</span
        >
      </div>
      <div
        class="flex-1 flex items-center justify-center bg-lagon-mayotte h-[24px] md:h-[26px] lg:h-[29px]"
      >
        <span
          class="font-heading font-semibold text-[8px] md:text-[10px] lg:text-xs text-white uppercase tracking-[1.44px]"
          >Transformation</span
        >
      </div>
      <div
        class="flex-1 flex items-center justify-center bg-sable-corail h-[24px] md:h-[26px] lg:h-[29px]"
      >
        <span
          class="font-heading font-semibold text-[8px] md:text-[10px] lg:text-xs text-white uppercase tracking-[1.44px]"
          >Distribution</span
        >
      </div>
      <div
        class="flex-1 flex items-center justify-center bg-brume-alize h-[24px] md:h-[26px] lg:h-[29px]"
      >
        <span
          class="font-heading font-semibold text-[8px] md:text-[10px] lg:text-xs text-white uppercase tracking-[1.44px]"
          >Logistique</span
        >
      </div>
      <div
        class="flex-1 flex items-center justify-center bg-ecume-poudree h-[24px] md:h-[26px] lg:h-[29px]"
      >
        <span
          class="font-heading font-semibold text-[8px] md:text-[10px] lg:text-xs text-white uppercase tracking-[1.44px]"
          >RH</span
        >
      </div>
    </div>

    <!-- Pêche Section -->
    <section id="peche" class="relative scroll-mt-[135px]">
      <!-- Overlay for text readability over blended ocean background -->
      <div class="absolute inset-0 bg-black/30"></div>

      <!-- Fish illustration (extends beyond left edge at desktop) -->
      <div class="hidden lg:block absolute left-[-172px] top-[245px] w-[735px] h-[279px] z-[1]">
        <Image
          src={fishIllustration}
          alt="Banc de thons — illustration pêche"
          class="w-full h-full object-contain"
          widths={[735]}
          sizes="735px"
        />
      </div>

      <Container class="relative z-10 pt-16 md:pt-24 lg:pt-[159px] pb-16 md:pb-24 lg:pb-[120px]">
        <div class="lg:ml-[41.3%]">
          <!-- Section title -->
          <h2
            class="font-display font-black text-[28px] leading-[34px] md:text-[36px] md:leading-[40px] lg:text-[40px] lg:leading-[44.5px] uppercase text-white max-w-[710px]"
          >
            Une pêche responsable
          </h2>

          <!-- Intro text -->
          <p
            class="font-heading font-normal text-base leading-relaxed md:text-lg md:leading-[1.461] lg:text-xl lg:leading-[1.461] text-white max-w-[701px] mt-8 md:mt-12 lg:mt-[42px]"
          >
            Reunimer maîtrise l'amont pour sécuriser l'aval. En accédant
            directement à la ressource, le Groupe garantit une matière première
            d'une fraîcheur irréprochable, totalement traçable et prélevée dans
            le respect des équilibres océaniques.
          </p>

          <!-- Subsection: Une puissance de pêche hauturière et australe -->
          <h3
            class="font-heading font-semibold text-base md:text-lg lg:text-xl text-white tracking-[-1px] mt-12 md:mt-16 lg:mt-[202px] max-w-[710px]"
          >
            Une puissance de pêche hauturière et australe
          </h3>
          <div class="w-full max-w-[710px] h-px bg-white/40 mt-4 lg:mt-[17px]"></div>

          <!-- La Réunion Stats -->
          <div class="mt-8 md:mt-10 lg:mt-[33px]">
            <div
              class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 lg:gap-[56px]"
            >
              <!-- Left column -->
              <div class="flex flex-col gap-[18px]">
                <p
                  class="font-body font-bold text-base leading-[1.4] text-white"
                >
                  À la Réunion
                </p>
                <!-- Stat row: 17 longliners -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >17</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >longliners de 13 et 25 m</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: 1 palangrier -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >1</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >palangrier de 68 m</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
              </div>

              <!-- Right column -->
              <div class="flex flex-col gap-3">
                <!-- Stat row: 130 marins -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >130</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >marins pêcheurs</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: 1800 tonnes -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >1800</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >tonnes de poissons pélagiques pêchés</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Subsection: Un modèle de collecte artisanale et de mareyage -->
          <h3
            class="font-heading font-semibold text-base md:text-lg lg:text-xl text-white tracking-[-1px] mt-12 md:mt-16 lg:mt-[100px] max-w-[710px]"
          >
            Un modèle de collecte artisanale et de mareyage
          </h3>
          <div class="w-full max-w-[710px] h-px bg-white/40 mt-4 lg:mt-[17px]"></div>

          <!-- Madagascar Stats + Image -->
          <div class="mt-8 md:mt-10 lg:mt-[33px]">
            <div class="flex flex-col lg:flex-row lg:gap-[54px]">
              <!-- Left: stats -->
              <div class="flex flex-col gap-[18px] lg:w-[326px] lg:shrink-0">
                <p
                  class="font-body font-bold text-base leading-[1.4] text-white"
                >
                  À Madagascar
                </p>
                <!-- Stat row: XX collecteurs -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >XX</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >Nombre de collecteurs</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: 86 bateaux -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >86</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >bateaux / pirogues de pêche artisanale</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: 5400 km -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >5400</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >km de littoral d'activité</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
              </div>

              <!-- Right: Madagascar image -->
              <div class="mt-6 lg:mt-0 lg:w-[330px] lg:h-[235px] rounded-[5px] overflow-hidden">
                <Image
                  src={pecheMadagascarImage}
                  alt="Pêche artisanale à Madagascar"
                  class="w-full h-full object-cover"
                  widths={[330, 660]}
                  sizes="(max-width: 1024px) 100vw, 330px"
                />
              </div>
            </div>
          </div>

          <!-- Boulogne-sur-Mer Stats + Image -->
          <div class="mt-10 md:mt-14 lg:mt-[62px]">
            <div class="flex flex-col lg:flex-row lg:gap-[54px]">
              <!-- Left: stats -->
              <div class="flex flex-col gap-[18px] lg:w-[326px] lg:shrink-0">
                <p
                  class="font-body font-bold text-base leading-[1.4] text-white"
                >
                  À Boulogne-sur-Mer
                </p>
                <!-- Stat row: 23 années -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >23</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >années d'expertise dans le mareyage</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: 8 bateaux -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >8</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >bateaux ou barques de pêche artisanale</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
                <!-- Stat row: XX tonnes -->
                <div class="flex flex-col gap-3">
                  <div class="flex items-end justify-between text-white">
                    <span
                      class="font-display font-black text-[32px] leading-[36px] md:text-[40px] md:leading-[44.5px] uppercase"
                      >XX</span
                    >
                    <span
                      class="font-body font-normal text-sm md:text-base leading-[1.4] text-right w-[140px] md:w-[181px]"
                      >tonnes de produits de la mer achetés</span
                    >
                  </div>
                  <div class="w-full h-px bg-white/40"></div>
                </div>
              </div>

              <!-- Right: Boulogne image placeholder -->
              <div class="mt-6 lg:mt-0 lg:w-[330px] lg:h-[247px] rounded-[5px] overflow-hidden bg-brume-alize/30">
                <!-- TODO: Replace with actual Boulogne image (Figma 729:16339) -->
              </div>
            </div>
          </div>

          <!-- Légine subtitle -->
          <p
            class="font-heading font-semibold text-base md:text-lg lg:text-xl text-white tracking-[-1px] mt-12 md:mt-16 lg:mt-[80px] max-w-[710px]"
          >
            Reunimer sur le marché de la pêche à la légine dans les TAAF
          </p>

          <!-- Pie Charts: Légine Quotas -->
          <div class="flex flex-col sm:flex-row gap-8 lg:gap-[49px] mt-8 md:mt-10 lg:mt-[57px]">
            <!-- Chart 1: 2024/25 — 91% / 9% -->
            <div class="relative pt-7 pb-7">
              <div class="relative w-[180px] h-[180px] md:w-[200px] md:h-[200px] lg:w-[234px] lg:h-[234px]">
                <svg viewBox="0 0 234 234" class="w-full h-full">
                  <!-- Background: bleu-abysse full circle -->
                  <circle cx="117" cy="117" r="90" fill="none" stroke="#002C41" stroke-width="27" />
                  <!-- Foreground: terre-laterite 91% arc, gap centered at top -->
                  <circle cx="117" cy="117" r="90" fill="none" stroke="#A34C26" stroke-width="27"
                    stroke-dasharray="514.59 50.89" stroke-dashoffset="-25.45"
                    transform="rotate(-90 117 117)" />
                </svg>
                <!-- Center text -->
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="font-heading font-semibold text-[24px] md:text-[28px] lg:text-[32px] text-white leading-tight">5542 T</span>
                  <span class="font-body font-normal text-xs md:text-sm lg:text-base text-white">2024/25</span>
                </div>
              </div>
              <!-- Top percentage (bleu-abysse slice) -->
              <p class="absolute top-0 left-1/2 -translate-x-1/2 font-body font-bold text-xs md:text-sm lg:text-base text-bleu-abysse">9%</p>
              <!-- Bottom percentage (terre-laterite slice) -->
              <p class="absolute bottom-0 left-1/2 -translate-x-1/2 font-body font-bold text-xs md:text-sm lg:text-base text-white">91%</p>
            </div>

            <!-- Chart 2: 2025/26 — 89% / 11% -->
            <div class="relative pt-7 pb-7">
              <div class="relative w-[180px] h-[180px] md:w-[200px] md:h-[200px] lg:w-[234px] lg:h-[234px]">
                <svg viewBox="0 0 234 234" class="w-full h-full">
                  <!-- Background: bleu-abysse full circle -->
                  <circle cx="117" cy="117" r="90" fill="none" stroke="#002C41" stroke-width="27" />
                  <!-- Foreground: terre-laterite 89% arc, gap centered at top -->
                  <circle cx="117" cy="117" r="90" fill="none" stroke="#A34C26" stroke-width="27"
                    stroke-dasharray="503.28 62.2" stroke-dashoffset="-31.1"
                    transform="rotate(-90 117 117)" />
                </svg>
                <!-- Center text -->
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="font-heading font-semibold text-[24px] md:text-[28px] lg:text-[32px] text-white leading-tight">4780 T</span>
                  <span class="font-body font-normal text-xs md:text-sm lg:text-base text-white">2025/26</span>
                </div>
              </div>
              <!-- Top percentage (bleu-abysse slice) -->
              <p class="absolute top-0 left-1/2 -translate-x-1/2 font-body font-bold text-xs md:text-sm lg:text-base text-bleu-abysse">11%</p>
              <!-- Bottom percentage (terre-laterite slice) -->
              <p class="absolute bottom-0 left-1/2 -translate-x-1/2 font-body font-bold text-xs md:text-sm lg:text-base text-white">89%</p>
            </div>
          </div>

          <!-- Certifications -->
          <div class="mt-12 md:mt-16 lg:mt-[83px]">
            <h3
              class="font-heading font-semibold text-base md:text-lg lg:text-xl text-white tracking-[-1px] max-w-[467px]"
            >
              Une exigence de durabilité certifiée
            </h3>
            <div class="w-full max-w-[710px] h-px bg-white/40 mt-4 lg:mt-[46px]"></div>

            <p
              class="font-body font-normal text-sm md:text-base leading-[1.4] text-white mt-4 lg:mt-[21px] max-w-[543px]"
            >
              Notre stratégie repose sur la sélectivité des espèces et le respect
              rigoureux des quotas et des saisons. Cet engagement est validé par
              des certifications internationales de référence :
            </p>

            <!-- Logos and certification list -->
            <div
              class="mt-8 md:mt-10 lg:mt-[108px] flex flex-col md:flex-row gap-8 md:gap-10 lg:gap-[80px] items-start"
            >
              <!-- MSC logo + dates -->
              <div class="flex items-start gap-6 lg:gap-[32px]">
                <img
                  src="/icons/logo-msc.svg"
                  alt="Label MSC — Marine Stewardship Council"
                  class="w-[80px] md:w-[109px] h-auto"
                />
                <div
                  class="font-body font-normal text-sm md:text-base leading-[1.4] text-white"
                >
                  <p>Espadon (2016)</p>
                  <p>Légine (2025)</p>
                  <p>Thon Germon (2026)</p>
                </div>
              </div>

              <!-- Ecolabel logo + dates -->
              <div class="flex items-start gap-6 lg:gap-[32px]">
                <img
                  src="/icons/logo-ecolabel.svg"
                  alt="Label Écolabel — certification durable"
                  class="w-[100px] md:w-[146px] h-auto"
                />
                <div
                  class="font-body font-normal text-sm md:text-base leading-[1.4] text-white"
                >
                  <p>Légine (2022)</p>
                  <p>Grenadier (2025)</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Tuna solo image (transition to next section) -->
    <div class="relative z-10 mt-12 md:mt-16 lg:mt-[120px]">
      <Container>
        <Image
          src={thonSeulImage}
          alt="Un thon, symbole de l'excellence halieutique de Reunimer"
          class="w-full -mb-[24%] max-w-[1045px] h-auto"
          widths={[375, 768, 1024]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 80vw, 1045px"
        />
      </Container>
    </div>
  </div>

  <!-- Transformation Section: "Une production experte" -->
  <section id="transformation" class="relative overflow-hidden scroll-mt-[135px]">
    <!-- Section title on gradient bg -->
    <div
      class="relative bg-gradient-to-b from-white to-[#ccc] py-12 md:py-16 lg:py-[16px]"
    >
      <Container>
        <h2
          class="font-display font-black text-[28px] leading-[34px] md:text-[36px] md:leading-[40px] lg:text-[40px] lg:leading-[44.5px] uppercase text-lagon-mayotte text-center"
        >
          Une production experte
        </h2>
      </Container>
    </div>

    <!-- First transformation area: 6 unités (light bg, left-aligned) -->
    <div class="relative overflow-hidden">
      <Image
        src={transformation1Image}
        alt="Unités de première transformation — gradage et découpe de précision"
        class="absolute inset-0 w-full h-full object-cover opacity-20"
        widths={[375, 768, 1024, 1440]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-white/80 to-[#ccc]/80">
      </div>

      <Container class="relative z-10 py-16 md:py-24 lg:py-[120px]">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
          <!-- Left content -->
          <div>
            <span
              class="font-display font-black text-[48px] leading-[1] md:text-[56px] lg:text-[64px] lg:leading-[44.5px] uppercase text-bleu-abysse"
            >
              6
            </span>
            <h3
              class="font-heading font-semibold text-base md:text-lg lg:text-xl text-bleu-abysse tracking-[-1px] mt-4 lg:mt-[59px]"
            >
              unités de première transformation
            </h3>
            <p
              class="font-body font-normal text-sm md:text-base leading-[1.4] text-bleu-abysse mt-4 lg:mt-[36px] max-w-[339px]"
            >
              Spécialisées dans le gradage et la découpe de précision (filets,
              longes), nos ateliers traitent une diversité unique
              d'espèces&nbsp;:<br />
              poissons pélagiques et tropicaux, céphalopodes et crustacés.
            </p>
          </div>

          <!-- Right: transformation image -->
          <div
