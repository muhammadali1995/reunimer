---
import PageLayout from "../layouts/PageLayout.astro";
import ExpertisesHeroSection from "../components/sections/expertises/ExpertisesHeroSection.astro";
import ExpertisesStickyNav from "../components/sections/expertises/ExpertisesStickyNav.astro";
import ExpertisesFishingSection from "../components/sections/expertises/ExpertisesFishingSection.astro";
import ExpertisesTransformationSection from "../components/sections/expertises/ExpertisesTransformationSection.astro";
import ExpertisesQualitySection from "../components/sections/expertises/ExpertisesQualitySection.astro";
import ExpertisesDistributionSection from "../components/sections/expertises/ExpertisesDistributionSection.astro";
import ExpertisesBrandsSection from "../components/sections/expertises/ExpertisesBrandsSection.astro";
import ExpertisesSupportSection from "../components/sections/expertises/ExpertisesSupportSection.astro";
import ExpertisesRhSection from "../components/sections/expertises/ExpertisesRhSection.astro";
import { expertisesFishingBackground } from "../data/expertises";
import { Image } from "astro:assets";
---

<PageLayout
  title="Nos Expertises - Reunimer"
  description="Découvrez les expertises du groupe Reunimer : pêche, transformation, distribution, logistique et ressources humaines."
>
  <ExpertisesHeroSection />
  <div class="sticky top-[92px] z-30 -mt-6 -mb-[47px] lg:top-[136px]">
    <ExpertisesStickyNav />
  </div>
  <div class="relative">
    <Image
      src={expertisesFishingBackground}
      alt="Banc de thons sous la surface"
      class="absolute inset-x-0 -top-[10%] h-[110%] w-full object-cover"
      widths={[768, 1024, 1440, 1920]}
      sizes="100vw"
    />

    <div id="peche" class="scroll-mt-[150px] lg:scroll-mt-[194px]">
      <ExpertisesFishingSection />
    </div>
  </div>
  <div id="transformation" class="scroll-mt-[150px] lg:scroll-mt-[194px]">
    <ExpertisesTransformationSection />
  </div>
  <ExpertisesQualitySection />
  <div id="distribution" class="scroll-mt-[150px] lg:scroll-mt-[194px]">
    <ExpertisesDistributionSection />
  </div>
  <ExpertisesBrandsSection />
  <div id="logistique" class="scroll-mt-[150px] lg:scroll-mt-[194px]">
    <ExpertisesSupportSection />
  </div>
  <div id="rh" class="scroll-mt-[150px] lg:scroll-mt-[194px]">
    <ExpertisesRhSection />
  </div>
</PageLayout>

<script>
  import { initExpertisesPage } from "../scripts/expertisesPage.js";

  initExpertisesPage();
  document.addEventListener('astro:after-swap', initExpertisesPage);
</script>
