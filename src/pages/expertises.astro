---
import PageLayout from "../layouts/PageLayout.astro"
import ExpertisesHeroSection from "../components/sections/expertises/ExpertisesHeroSection.astro"
import ExpertisesStickyNav from "../components/sections/expertises/ExpertisesStickyNav.astro"
import ExpertisesFishingSection from "../components/sections/expertises/ExpertisesFishingSection.astro"
import ExpertisesTransformationSection from "../components/sections/expertises/ExpertisesTransformationSection.astro"
import ExpertisesQualitySection from "../components/sections/expertises/ExpertisesQualitySection.astro"
import ExpertisesDistributionSection from "../components/sections/expertises/ExpertisesDistributionSection.astro"
import ExpertisesBrandsSection from "../components/sections/expertises/ExpertisesBrandsSection.astro"
import ExpertisesSupportSection from "../components/sections/expertises/ExpertisesSupportSection.astro"
import ExpertisesRhSection from "../components/sections/expertises/ExpertisesRhSection.astro"
import {
  expertisesFishingBackground,
  expertisesSmokeImage,
  expertisesTunaImage,
} from "../data/expertises"
import {Image} from "astro:assets"
import fishWhiteImage from "../assets/images/expertise/fish-white.png"
import knifeImage from "../assets/images/expertise/knife.png"
---

<PageLayout
  title="Nos Expertises - Reunimer"
  description="Découvrez les expertises du groupe Reunimer : pêche, transformation, distribution, logistique et ressources humaines."
>
  <ExpertisesHeroSection />
  <div class="sticky top-0 z-40 -mt-6 -mb-[47px]" id="expertise-sticky-tabs">
    <ExpertisesStickyNav />
  </div>
  <div class="relative md:-mt-[412px]">
    <Image
      src={expertisesFishingBackground}
      alt="Banc de thons sous la surface"
      class="absolute inset-x-0 top-0 h-[170%] w-full object-cover"
      data-sea-parallax-bg
      widths={[768, 1024, 1440, 1920]}
      sizes="100vw"
    />

    <div
      id="peche"
      class="scroll-mt-[var(--sticky-tabs-offset,150px)] md:pt-[129px]"
    >
      <ExpertisesFishingSection />
    </div>
  </div>

  <!-- Fish & knife: pinned in viewport, sits above the next section (z-30).
       The transformation section (z-20) scrolls up behind it, its white bg
       acting as a natural mask. When it reaches the fish midpoint, the pin
       releases and the fish scrolls away with 100px gap before content. -->
  <div id="fish-pin-wrapper" class="relative z-30 py-20 lg:py-[120px]">
    <div class="mx-auto w-full max-w-[1000px] px-5 md:px-8">
      <div class="relative" data-fish-curtain-stage>
        <Image
          src={expertisesTunaImage}
          alt=""
          aria-hidden="true"
          class="pointer-events-none opacity-0 w-full"
          widths={[768, 1200, 1600]}
          sizes="(min-width: 1280px) 1000px, 100vw"
        />
        <div
          class="absolute inset-0"
          data-fish-curtain-secondary-mask
          style="clip-path: inset(0 0 100% 0);"
        >
          <Image
            src={fishWhiteImage}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 w-full object-fill scale-x-[-1]"
            data-fish-curtain-secondary
            widths={[768, 1200, 1600]}
            sizes="(min-width: 1280px) 1000px, 100vw"
          />
        </div>
        <div
          class="absolute inset-0 overflow-hidden"
          data-fish-curtain-primary-mask
          style="clip-path: inset(0 0 0 0);"
        >
          <Image
            src={expertisesTunaImage}
            alt="Illustration de thons"
            class="absolute inset-0 h-full w-full object-fill"
            data-fish-curtain-primary
            widths={[768, 1200, 1600]}
            sizes="(min-width: 1280px) 1000px, 100vw"
          />
        </div>
      </div>
    </div>
  </div>

  <div
    id="transformation"
    class="relative z-20 pt-10 scroll-mt-[var(--sticky-tabs-offset,150px)]"
  >
    <ExpertisesTransformationSection />
  </div>
  <!-- Smoke sits at the border between transformation and quality sections -->
  <div class="absolute -mt-[20%] z-20 pointer-events-none w-full">
    <Image
      src={expertisesSmokeImage}
      alt=""
      aria-hidden="true"
      class="w-full"
      data-smoke-parallax="top"
    />
  </div>
  <div class="z-40">
    <ExpertisesQualitySection />
  </div>
  <div id="distribution" class="scroll-mt-[var(--sticky-tabs-offset,150px)]">
    <ExpertisesDistributionSection />
  </div>
  <ExpertisesBrandsSection />
  <div id="logistique" class="scroll-mt-[var(--sticky-tabs-offset,150px)]">
    <ExpertisesSupportSection />
  </div>
  <div id="rh" class="scroll-mt-[var(--sticky-tabs-offset,150px)]">
    <ExpertisesRhSection />
  </div>
</PageLayout>

<script>
  import {initExpertisesPage} from "../scripts/expertisesPage.js"

  initExpertisesPage()
  document.addEventListener("astro:after-swap", initExpertisesPage)
</script>
