        {merSection.partner!.description}
      </p>
    </div>
  </EngagementSection>

  <!-- Notre lien à la Terre -->
  <EngagementSection
    title={terreSection.title}
    bodyText={terreSection.bodyText}
    imageSrc={terreSection.image}
    imageAlt={terreSection.imageAlt}
    imagePosition={terreSection.imagePosition}
    bgColor={terreSection.bgColor}
    id={terreSection.id}
  >
    <!-- Bôndy partner logo + description -->
    <div
      class="mt-6 md:mt-8 lg:mt-[31px] flex flex-col sm:flex-row gap-4 lg:gap-6"
    >
