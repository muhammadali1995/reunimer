        <div class="flex flex-col lg:flex-row lg:gap-[60px] xl:gap-[100px]">
          <!-- Left: Title + body -->
          <div class="flex-1 max-w-[512px]">
            <h2 class="font-heading font-semibold text-xl leading-tight md:text-2xl lg:text-[32px] lg:leading-[39px] text-bleu-abysse">
              Notre lien aux fili&egrave;res
            </h2>
            <p class="mt-4 md:mt-6 lg:mt-[30px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse">
              Membre de l&rsquo;ADIR, Reunimer s&rsquo;engage pour l&rsquo;excellence industrielle de La R&eacute;union. En structurant la fili&egrave;re p&ecirc;che et en d&eacute;fendant la production locale, le groupe renforce la souverainet&eacute; alimentaire de l&rsquo;&icirc;le et valorise le savoir-faire r&eacute;unionnais au c&oelig;ur de l&rsquo;oc&eacute;an Indien.
            </p>
            <p class="mt-4 lg:mt-[22px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse">
              &Eacute;galement membre de l&rsquo;ARIPA, Reunimer s&rsquo;engage pour une fili&egrave;re p&ecirc;che et aquaculture structur&eacute;e &agrave; La R&eacute;union. Cette synergie interprofessionnelle assure la tra&ccedil;abilit&eacute; des produits, la stabilit&eacute; du march&eacute; et une gestion durable des ressources au service d&rsquo;une &eacute;conomie bleue locale et performante.
            </p>
          </div>

          <!-- Right: Logos + buttons -->
          <div class="mt-8 lg:mt-0 flex flex-col items-start lg:items-end">
            <div class="flex items-center gap-6 lg:gap-[74px]">
              <Image
                src={logoAdir}
                alt="Logo ADIR — Association pour le D&eacute;veloppement Industriel de La R&eacute;union"
                class="w-[100px] md:w-[120px] lg:w-[145px] h-auto"
                widths={[100, 120, 145]}
                sizes="145px"
              />
              <Image
                src={logoAripa}
                alt="Logo ARIPA — Association R&eacute;unionnaise Interprofessionnelle de la P&ecirc;che et de l'Aquaculture"
                class="w-[140px] md:w-[175px] lg:w-[207px] h-auto"
                widths={[140, 175, 207]}
                sizes="207px"
              />
            </div>
            <div class="mt-6 md:mt-8 lg:mt-[60px] xl:mt-[108px] flex flex-wrap gap-4 lg:gap-[40px] xl:gap-[80px]">
              <Button variant="outline-dark" href="#footer-contact-heading">
                En savoir plus
              </Button>
              <Button variant="outline-dark" href="#footer-contact-heading">
                En savoir plus
