      <div class="max-w-[1284px] mx-auto px-6 md:px-10 lg:px-[78px] py-10 md:py-14 lg:py-[47px]">
        <div class="flex flex-col sm:flex-row items-center gap-8 lg:gap-[120px] xl:gap-[260px]">
          <div class="shrink-0">
            <Image
              src={medailleEcovadis}
              alt="M&eacute;daille d'argent EcoVadis — performance RSE de Reunimer"
              class="w-[200px] md:w-[250px] lg:w-[304px] h-auto"
              widths={[200, 250, 304]}
              sizes="304px"
            />
          </div>
          <p class="font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[445px]">
            EcoVadis est une entreprise SaaS qui propose une gamme de solutions RSE con&ccedil;ues pour vous aider &agrave; g&eacute;rer, &agrave; mesurer et &agrave; am&eacute;liorer votre performance RSE dans l&rsquo;ensemble de la cha&icirc;ne de valeur.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
