        <!-- Together description -->
        <p
          class="mt-4 md:mt-5 lg:mt-[25px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[562px]"
        >
          {femmesHommesSection.description}
        </p>

        <!-- Button -->
        <div class="mt-5 md:mt-6 lg:mt-[25px]">
          <Button variant="outline-dark" href="#footer-contact-heading">
            En savoir plus
          </Button>
        </div>

        <!-- Key Figures -->
        <div class="mt-8 md:mt-10 lg:mt-[48px]">
          <h3
            class="font-body font-bold text-sm md:text-base lg:text-base lg:leading-[19.4px] text-bleu-abysse"
          >
            {femmesHommesSection.statsTitle}
          </h3>
          <div class="mt-4 lg:mt-[18px] max-w-[467px]">
            {
              femmesHommesSection.stats.map((stat) => {
                const parsed = parseCountValue(stat.value)
                return (
                  <div class="flex items-baseline justify-between gap-4 py-3 lg:py-[6px] border-b border-bleu-abysse/50 first:border-t first:border-t-bleu-abysse/50">
