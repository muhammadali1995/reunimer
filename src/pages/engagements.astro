      <p
        class="font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[280px]"
      >
        {terreSection.partner!.description}
      </p>
    </div>
  </EngagementSection>

  <!-- Notre lien aux femmes et aux hommes -->
  <section
    id={femmesHommesSection.id}
    class="bg-gris-clair relative overflow-hidden scroll-mt-[135px]"
