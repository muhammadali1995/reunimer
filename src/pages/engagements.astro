                      class="font-display font-black text-2xl md:text-3xl lg:text-[40px] lg:leading-[44.5px] text-bleu-abysse shrink-0"
                      data-count-value={
                        parsed ? parsed.numericValue : undefined
                      }
                      data-count-decimals={parsed ? parsed.decimals : undefined}
                      data-count-prefix={parsed ? parsed.prefix : undefined}
                      data-count-suffix={parsed ? parsed.suffix : undefined}
                    >
                      {stat.value}
                    </span>
                    <span class="font-body font-normal text-sm md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse text-right max-w-[220px] sm:max-w-none">
                      {stat.label}
                    </span>
                  </div>
                )
              })
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre lien à l'énergie -->
  <section
    id={energieSection.id}
    class="bg-white relative overflow-hidden scroll-mt-[135px]"
  >
    <div class="flex flex-col lg:flex-row-reverse lg:min-h-[785px]">
      <!-- Image column (RIGHT) -->
      <div
        class="relative w-full lg:w-[54.2%] shrink-0 overflow-hidden min-h-[300px] md:min-h-[400px] lg:min-h-0"
        data-engagement-parallax
      >
        <Image
          src={energieSection.image}
          alt={energieSection.imageAlt}
          class="absolute inset-0 w-full h-full object-cover object-left lg:hidden"
          widths={[375, 768, 1024]}
          sizes="100vw"
        />
        <div
          class="hidden lg:block absolute inset-x-0 top-0 h-[140%] w-full"
          data-parallax-img-wrapper
        >
          <Image
            src={energieSection.image}
            alt={energieSection.imageAlt}
            class="h-full w-full object-cover object-left"
            widths={[1024, 1440]}
            sizes="781px"
          />
        </div>
      </div>

      <!-- Text column -->
      <div
        class="flex-1 px-6 py-8 md:px-10 md:py-12 lg:py-[177px] lg:px-[60px] lg:pl-[165px]"
      >
        <h2
          class="font-heading font-semibold text-2xl leading-tight md:text-[28px] lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
        >
          Notre lien &agrave; l&rsquo;&eacute;nergie
        </h2>
        <p
          class="mt-5 md:mt-6 lg:mt-[52px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[445px]"
        >
          {energieSection.paragraphs[0]}
        </p>
        <p
          class="mt-4 lg:mt-[22px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[445px]"
        >
          {energieSection.paragraphs[1]}
        </p>
      </div>
    </div>
  </section>

  <!-- Notre lien à la santé -->
  <section
    id={santeSection.id}
    class="bg-gris-clair relative overflow-hidden scroll-mt-[135px]"
  >
    <div class="flex flex-col lg:flex-row lg:min-h-[785px]">
      <!-- Image column (LEFT) -->
      <div
        class="relative w-full lg:w-[49.3%] shrink-0 overflow-hidden min-h-[300px] md:min-h-[400px] lg:min-h-0"
        data-engagement-parallax
      >
        <Image
          src={santeSection.image}
          alt={santeSection.imageAlt}
          class="absolute inset-0 w-full h-full object-cover object-right lg:hidden"
          widths={[375, 768, 1024]}
          sizes="100vw"
        />
        <div
          class="hidden lg:block absolute inset-x-0 top-0 h-[140%] w-full"
          data-parallax-img-wrapper
        >
          <Image
            src={santeSection.image}
            alt={santeSection.imageAlt}
            class="h-full w-full object-cover object-right"
            widths={[1024, 1440]}
            sizes="710px"
          />
        </div>
      </div>

      <!-- Text column -->
      <div
        class="flex-1 px-6 py-8 md:px-10 md:py-12 lg:py-[216px] lg:px-[88px]"
      >
        <h2
          class="font-heading font-semibold text-2xl leading-tight md:text-[28px] lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
        >
          Notre lien &agrave; la sant&eacute;
        </h2>
        <p
          class="mt-4 md:mt-5 lg:mt-[17px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[496px]"
        >
          {santeSection.paragraphs[0]}
        </p>
        <p
          class="mt-4 lg:mt-[22px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[496px]"
        >
          {santeSection.paragraphs[1]}
        </p>
      </div>
    </div>
  </section>

  <!-- Notre lien à la formation -->
  <EngagementSection
    title={formationSection.title}
    bodyText={formationSection.bodyText}
    imageSrc={formationSection.image}
    imageAlt={formationSection.imageAlt}
    imagePosition={formationSection.imagePosition}
    bgColor={formationSection.bgColor}
    id={formationSection.id}
    showButton={formationSection.showButton}
  />

  <!-- Notre lien au social -->
  <section
    id={socialSection.id}
    class="bg-gris-clair relative overflow-hidden scroll-mt-[135px]"
  >
    <div class="flex flex-col lg:flex-row lg:min-h-[1141px]">
      <!-- Image column (LEFT) -->
      <div
        class="relative w-full lg:w-[49.3%] shrink-0 overflow-hidden min-h-[300px] md:min-h-[400px] lg:min-h-0"
        data-engagement-parallax
      >
        <Image
          src={socialSection.image}
          alt={socialSection.imageAlt}
          class="absolute inset-0 w-full h-full object-cover object-right lg:hidden"
          widths={[375, 768, 1024]}
          sizes="100vw"
        />
        <div
          class="hidden lg:block absolute inset-x-0 top-0 h-[140%] w-full"
          data-parallax-img-wrapper
        >
          <Image
            src={socialSection.image}
            alt={socialSection.imageAlt}
            class="h-full w-full object-cover object-right"
            widths={[1024, 1440]}
            sizes="948px"
          />
        </div>
      </div>

      <!-- Text column -->
      <div
        class="flex-1 px-6 py-8 md:px-10 md:py-12 lg:px-[88px] lg:py-[132px]"
      >
        <h2
          class="font-heading font-semibold text-2xl leading-tight md:text-[28px] lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
        >
          {socialSection.title}
        </h2>

        <p
          class="mt-4 md:mt-5 lg:mt-[36px] font-heading font-normal text-base leading-relaxed md:text-lg md:leading-[1.461] lg:text-xl lg:leading-[29.2px] text-bleu-abysse max-w-[512px]"
        >
          {socialSection.subtitle}
        </p>

        <p
          class="mt-4 md:mt-5 lg:mt-[15px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[512px]"
        >
          {socialSection.bodyText}
        </p>

        <div class="mt-6 md:mt-8 lg:mt-[30px]">
          <Image
            src={socialSection.logo}
            alt={socialSection.logoAlt}
            class="w-[180px] md:w-[195px] lg:w-[209px] h-auto"
            widths={[180, 195, 209]}
            sizes="209px"
          />
        </div>

        <div class="mt-6 md:mt-8 lg:mt-[31px]">
          <Button variant="outline-dark" href="#footer-contact-heading">
            En savoir plus
          </Button>
        </div>

        <div class="mt-10 md:mt-12 lg:mt-[132px] max-w-[487px]">
          <div class="border-t border-bleu-abysse/50 pt-5 lg:pt-[33px]">
            <h3
              class="font-heading font-semibold text-base leading-tight md:text-lg lg:text-[20px] lg:leading-[24.4px] text-bleu-abysse tracking-[-1px]"
            >
              {socialSection.statsTitle}
            </h3>

            <div
              class="mt-5 lg:mt-[25px] grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6"
            >
              {
                socialSection.stats.map((stat) => {
                  const parsed = parseCountValue(stat.value)
                  return (
                    <div class="flex flex-col gap-2">
                      <span
                        class="font-display font-black text-2xl md:text-3xl lg:text-[40px] lg:leading-[44.5px] text-bleu-abysse"
                        data-count-value={
                          parsed ? parsed.numericValue : undefined
                        }
                        data-count-decimals={
                          parsed ? parsed.decimals : undefined
                        }
                        data-count-prefix={parsed ? parsed.prefix : undefined}
                        data-count-suffix={parsed ? parsed.suffix : undefined}
                      >
                        {stat.value}
                      </span>
                      <span class="font-body font-normal text-sm md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse">
                        {stat.label}
                      </span>
                    </div>
                  )
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre lien aux filières -->
  <section
    id={filieresSection.id}
    class="relative overflow-hidden scroll-mt-[135px] bg-white"
  >
    <div
      class="relative px-6 py-12 md:px-10 md:py-16 lg:px-[88px] lg:pt-[132px] lg:pb-[110px]"
    >
      <h2
        class="font-heading font-semibold text-xl leading-tight md:text-2xl lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
      >
        {filieresSection.title}
      </h2>

      <div
        class="mt-10 md:mt-12 lg:mt-[56px] flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-[72px]"
      >
        <div class="lg:max-w-[512px] lg:flex-none">
          <div class="flex flex-col gap-4">
            <p
              class="font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse"
            >
              {filieresSection.paragraphs[0]}
            </p>

            <p
              class="font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse"
            >
              {filieresSection.paragraphs[1]}
            </p>
          </div>
        </div>

        <div
          class="flex flex-col gap-8 sm:flex-row sm:flex-wrap lg:flex-row lg:items-start lg:gap-[80px]"
        >
          <div
            class="flex flex-col items-start justify-between gap-6 pb-4"
            style="height:stretch"
          >
            <Image
              src={filieresSection.partners[0].logo}
              alt={filieresSection.partners[0].alt}
              class="w-[125px] md:w-[135px] lg:w-[145px] h-auto"
              widths={[125, 135, 145]}
              sizes="145px"
            />
            <Button variant="outline-dark" href="#footer-contact-heading">
              En savoir plus
            </Button>
          </div>

          <div
            class="flex flex-col items-start justify-between gap-6 h-[fill-available] pb-4"
          >
            <Image
              src={filieresSection.partners[1].logo}
              alt={filieresSection.partners[1].alt}
              class="w-[160px] md:w-[185px] lg:w-[207px] h-auto"
              widths={[160, 185, 207]}
              sizes="207px"
            />
            <Button variant="outline-dark" href="#footer-contact-heading">
              En savoir plus
            </Button>
          </div>
        </div>
      </div>

      <div
        class="mt-12 md:mt-14 lg:mt-[86px] flex flex-col gap-8 bg-gris-clair w-full px-6 py-8 md:px-8 md:py-10 lg:flex-row lg:items-center lg:justify-between lg:gap-[82px] lg:px-[84px] lg:py-[58px]"
      >
        <div class="lg:flex-none">
          <Image
            src={filieresSection.medal}
            alt={filieresSection.medalAlt}
            class="w-[220px] md:w-[260px] lg:w-[304px] h-auto"
            widths={[220, 260, 304]}
            sizes="304px"
          />
