---
import {Image} from "astro:assets"
import PageLayout from "../layouts/PageLayout.astro"
import Container from "../components/ui/Container.astro"
import Button from "../components/ui/Button.astro"
import EngagementSection from "../components/ui/EngagementSection.astro"
import {
  engagementsSeo,
  engagementsHero,
  introLabels,
  introReport,
  merSection,
  terreSection,
  femmesHommesSection,
  energieSection,
  santeSection,
  formationSection,
  socialSection,
  filieresSection,
} from "../data/engagements"

function parseCountValue(value: string) {
  const match = value.match(/^([^0-9]*)([0-9]+(?:[.,][0-9]+)?)(.*)$/u)
  if (!match) return null
  const decimalPart = match[2].match(/[.,](\d+)$/u)
  return {
    prefix: match[1],
    numericValue: Number(match[2].replace(",", ".")),
    suffix: match[3],
    decimals: decimalPart ? decimalPart[1].length : 0,
  }
}
---

<PageLayout
  title={engagementsSeo.title}
  description={engagementsSeo.description}
>
  <!-- Hero Section -->
  <section class="relative -mt-[92px] h-[calc(100vh+92px)]" data-engagements-hero>
    <div
      class="relative h-full overflow-hidden"
      data-engagement-parallax
    >
      <Image
        src={engagementsHero.image}
        alt={engagementsHero.imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        widths={[375, 768, 1024, 1440]}
        sizes="100vw"
      />

      <!-- Text overlay — centered mobile, right-side desktop -->
      <div
        class="absolute inset-0 bg-gradient-to-t from-bleu-abysse/80 via-bleu-abysse/30 to-transparent lg:bg-none"
      >
        <div
          class="absolute inset-x-0 bottom-0 px-5 pb-8 pt-20 text-left sm:px-6 sm:pb-10 md:px-10 md:max-w-[640px] lg:max-w-none lg:inset-auto lg:bottom-auto lg:px-0 lg:pb-0 lg:pt-0 lg:text-left lg:top-[297px] lg:left-[49.65%] lg:w-[559px]"
        >
          <h1
            data-anim="2"
            class="max-w-[260px] font-display font-black text-[24px] leading-[1.02] sm:max-w-[340px] sm:text-[28px] md:max-w-[420px] md:text-[34px] lg:max-w-none lg:text-[40px] lg:leading-[44.5px] uppercase text-white drop-shadow-[0_4px_16.2px_rgba(0,0,0,0.51)]"
