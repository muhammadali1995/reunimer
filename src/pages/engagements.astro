          widths={[120, 150, 175]}
          sizes="175px"
        />
      </div>
      <p
        class="font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-bleu-abysse max-w-[218px]"
