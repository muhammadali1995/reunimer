            <span class="lg:hidden">
              {engagementsHero.title}
            </span>
            <span class="hidden lg:inline">
              Un engagement<br />humain et<br />environnemental<br />porteur
              d&rsquo;avenir
            </span>
          </h1>
          <p
            data-anim="2"
            class="mt-3 max-w-[320px] font-heading font-normal text-[13px] leading-[1.45] sm:mt-4 sm:max-w-[420px] sm:text-sm md:mt-5 md:max-w-[520px] md:text-base lg:mt-[20px] lg:max-w-[659px] lg:text-xl lg:leading-[1.461] text-white"
          >
            {engagementsHero.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro: ONG placeholder labels -->
  <section class="bg-white pt-10 md:pt-14 lg:pt-[59px]">
    <Container>
      <div
        class="flex flex-col gap-4 sm:flex-row sm:justify-between sm:gap-10 lg:gap-[445px]"
      >
        <h2
          class="font-heading font-semibold text-2xl md:text-[28px] lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
        >
          {introLabels.left}
        </h2>
        <h2
          class="font-heading font-semibold text-2xl md:text-[28px] lg:text-[32px] lg:leading-[39px] text-bleu-abysse"
        >
          {introLabels.right}
        </h2>
      </div>
    </Container>
  </section>

  <!-- Intro: Explorez nos Engagements + RSE report -->
  <section class="relative mt-8 md:mt-10 lg:mt-[60px] overflow-hidden">
    <!-- Background image — RSE report on wooden dock -->
    <div class="relative h-[300px] sm:h-[380px] md:h-[450px] lg:h-[516px]">
      <Image
        src={introReport.image}
        alt={introReport.imageAlt}
        class="w-full h-full object-cover"
        widths={[375, 768, 1024, 1440]}
        sizes="100vw"
      />

      <!-- Text overlay — left side -->
      <div
        class="absolute inset-0 flex flex-col justify-center bg-gradient-to-r from-bleu-abysse/35 via-bleu-abysse/10 to-transparent px-6 md:px-10 lg:bg-none lg:pl-[126px] lg:pr-0 lg:pt-[84px] lg:justify-start"
      >
        <h2
          class="font-heading font-semibold text-2xl leading-tight md:text-[28px] lg:text-[32px] lg:leading-[39px] text-white"
        >
          Explorez nos<br />Engagements
        </h2>
        <p
          class="mt-4 md:mt-6 lg:mt-[21px] font-body font-normal text-sm leading-[1.4] md:text-base lg:text-base lg:leading-[22.4px] text-white max-w-[445px]"
        >
          {introReport.description}
        </p>
        <div class="mt-6 md:mt-8 lg:mt-[29px]">
          <Button variant="outline-light" href={introReport.buttonHref}>
            {introReport.buttonLabel}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre lien à la Mer -->
  <EngagementSection
    title={merSection.title}
    bodyText={merSection.bodyText}
    imageSrc={merSection.image}
    imageAlt={merSection.imageAlt}
    imagePosition={merSection.imagePosition}
    bgColor={merSection.bgColor}
    id={merSection.id}
  >
    <!-- Kelonia partner logo + description -->
    <div
      class="mt-6 md:mt-8 lg:mt-[31px] flex flex-col sm:flex-row gap-4 lg:gap-6"
    >
      <div class="shrink-0">
        <Image
          src={merSection.partner!.logo}
          alt={merSection.partner!.alt}
