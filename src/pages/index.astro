---
import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/home/hero-home.png';
import wordmark from '../assets/logos/reunimer-wordmark.svg';
import groupeImage1 from '../assets/images/home/home-groupe-1.png';
import groupeImage2 from '../assets/images/home/home-groupe-2.png';
import groupeImage3 from '../assets/images/home/home-groupe-3.png';
import rseSilhouette from '../assets/images/home/home-rse-silhouette.png';
import homeCarriere from '../assets/images/home/home-carriere.png';
import ArticleCard from '../components/ui/ArticleCard.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { filialeLogos, homeExpertiseCards } from '../data/home';
import { featuredLargeArticle, featuredSmallArticles } from '../data/articles';
---

<PageLayout>
	<!-- Hero Section -->
	<section class="relative -mt-[92px] h-[500px] md:h-[700px] lg:h-[860px] overflow-hidden">
		<Image
			src={heroImage}
			alt="Vue aérienne de l'océan"
			class="absolute inset-0 w-full h-full object-cover"
			widths={[768, 1024, 1440, 1920]}
			sizes="100vw"
		/>
		<div class="absolute inset-0 flex items-center justify-center">
			<img
				src={wordmark.src}
				alt="REUNIMER"
				class="w-[300px] md:w-[420px] lg:w-[540px] h-auto"
			/>
		</div>
	</section>

	<!-- Groupe Section -->
	<section id="groupe-section" class="bg-gris-clair">
		<Container>
			<div class="flex flex-col lg:flex-row lg:h-[572px] py-12 md:py-16 lg:py-0">
				<!-- Text Column -->
				<div class="lg:w-[38%] lg:pt-[104px] lg:pr-8 mb-10 lg:mb-0 lg:shrink-0">
					<h2 data-anim="1" class="font-display text-[32px] lg:text-display-lg uppercase text-bleu-abysse leading-[1.1] lg:leading-[44.5px] mb-6">
						Les trésors d'aujourd'hui, l'héritage de demain.
					</h2>
					<p data-anim="2" class="font-heading font-normal text-lg lg:text-heading-lg text-bleu-abysse leading-[1.461] mb-8">
						Chez Reunimer, nous croyons que la performance durable naît de l'équilibre entre le respect de la nature...
					</p>
					<div data-anim="2">
						<Button variant="outline-dark" href="/groupe">
							Découvrez notre groupe
						</Button>
					</div>
				</div>

				<!-- Images Column -->
				<div class="lg:w-[58%] lg:ml-auto flex gap-2 h-[250px] md:h-[350px] lg:h-auto lg:py-[60px]">
					<div data-anim="3" class="flex-1 overflow-hidden">
						<Image
							src={groupeImage1}
							alt="Bateau de pêche Reunimer"
							class="w-full h-full object-cover"
							widths={[280, 400]}
							sizes="(max-width: 1024px) 33vw, 280px"
						/>
					</div>
					<div data-anim="3" class="flex-1 overflow-hidden">
						<Image
							src={groupeImage2}
							alt="Banc de poissons dans l'océan"
							class="w-full h-full object-cover"
							widths={[255, 400]}
							sizes="(max-width: 1024px) 33vw, 260px"
						/>
					</div>
					<div data-anim="3" class="flex-1 overflow-hidden">
						<Image
							src={groupeImage3}
							alt="Pêcheur Reunimer souriant"
							class="w-full h-full object-cover"
							widths={[270, 400]}
							sizes="(max-width: 1024px) 33vw, 270px"
						/>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- Expertises Section -->
	<section class="bg-white py-12 md:py-16 lg:py-0 lg:h-[902px] lg:relative">
		<!-- Title -->
		<div class="text-center mb-8 lg:mb-0 lg:absolute lg:inset-x-0 lg:top-[88px]">
			<h2 class="font-display text-[32px] lg:text-display-lg uppercase text-bleu-abysse leading-[44.5px]">
				Nos expertises
			</h2>
			<p class="font-heading font-normal text-lg lg:text-heading-lg text-bleu-abysse leading-[1.461] mt-2">
				Nos expertises dans la chaîne de valeurs intégrée.
			</p>
		</div>

		<!-- Cards -->
		<div class="flex gap-3 md:gap-4 lg:gap-0 overflow-x-auto lg:overflow-visible px-5 md:px-10 lg:px-0 lg:absolute lg:inset-x-[35px] lg:top-[245px] lg:bottom-[41px] snap-x snap-mandatory">
			{homeExpertiseCards.map((card) => (
				<a
					href={card.href}
					data-expertise-card
					class="relative flex-none w-[240px] md:w-[280px] lg:w-auto lg:flex-1 h-[380px] md:h-[520px] lg:h-full overflow-hidden snap-start rounded-sm lg:rounded-none"
				>
					{/* Background Image */}
					<Image
						src={card.image}
						alt={card.title}
						class="absolute inset-0 w-full h-full object-cover"
						widths={[300, 600]}
						sizes="(max-width: 1024px) 260px, 274px"
					/>

					{/* Hover panel — slides up from bottom */}
					<div
						data-panel
						class:list={[
							card.color,
							'absolute inset-x-0 bottom-0 h-full flex flex-col px-[25px] pt-[15px] pb-[25px]',
						]}
					>
						<h3 class="font-heading font-medium text-2xl md:text-[32px] text-white leading-[1.461]">
							{card.title}
						</h3>
						<hr data-reveal class="border-white/50 mt-4 mb-5" />
						<p data-reveal class="font-heading font-normal text-base md:text-lg text-white/90 leading-[1.461]">
							{card.description}
						</p>
						<div data-reveal class="mt-auto">
							<span class="inline-flex items-center gap-2 font-display text-xs md:text-sm uppercase text-white border border-white px-5 py-2.5 tracking-wider">
								En savoir plus
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- RSE Engagement Section -->
	<section id="rse-section" class="bg-gris-clair relative overflow-hidden py-12 md:py-16 lg:py-0 lg:h-[752px]">
		<!-- Silhouette Image -->
		<div data-anim="3" class="relative mx-auto max-w-[300px] md:max-w-[340px] lg:max-w-none lg:absolute lg:left-[5%] lg:top-[29px] lg:bottom-0 lg:w-[34.28%] mb-10 lg:mb-0">
			<Image
				src={rseSilhouette}
				alt="Collage en silhouette humaine — équipe Reunimer"
				class="w-full h-full object-cover object-top"
				widths={[400, 600, 900]}
				sizes="(max-width: 1024px) 300px, 494px"
			/>
		</div>

		<!-- Text Content -->
		<div data-anim="4" class="px-5 md:px-10 lg:px-0 lg:absolute lg:top-[31.38%] lg:left-[42.11%] lg:right-[7.27%]">
			<h2 class="font-display text-[28px] md:text-[32px] lg:text-display-lg uppercase text-bleu-abysse leading-[1.1] lg:leading-[44.5px] mb-6 lg:mb-0">
				Un engagement humain et environnemental porteur d'avenir
			</h2>
		</div>
		<div data-anim="4" class="px-5 md:px-10 lg:px-0 lg:absolute lg:top-[53.59%] lg:left-[42.11%] lg:right-[20.29%]">
			<p class="font-heading font-normal text-lg lg:text-heading-lg text-bleu-abysse leading-[1.461] mb-8 lg:mb-0">
				Chez Reunimer, nous croyons que la performance durable naît de l'équilibre entre le respect de la nature et l'épanouissement des hommes...
			</p>
		</div>
		<div data-anim="4" class="px-5 md:px-10 lg:px-0 lg:absolute lg:top-[71.68%] lg:left-[42.11%]">
			<Button variant="outline-dark" href="/engagements">
				Découvrez notre engagement
			</Button>
		</div>
	</section>

	<!-- Filiales Section -->
	<section class="bg-white py-12 md:py-16 lg:py-0 lg:h-[288px] overflow-hidden">
		<Container>
			<div class="flex flex-col lg:flex-row lg:items-center lg:h-[288px] gap-8 lg:gap-0">
				<!-- Left: Title + Button -->
				<div class="lg:w-[35%] lg:shrink-0 flex flex-col gap-6 lg:pt-[61px] lg:pb-[88px]">
					<SectionHeading title="Nos filiales" align="center" />
					<div class="w-fit">
						<Button variant="outline-dark" href="/groupe">
							Découvrez nos filiales
						</Button>
					</div>
				</div>

				<!-- Right: Logo Carousel -->
				<div class="lg:flex-1 lg:ml-auto overflow-hidden">
					<div class="flex items-center gap-10 md:gap-[66px] animate-scroll">
						{[...filialeLogos, ...filialeLogos].map((logo) => (
							<img
								src={logo.src.src}
								alt={logo.alt}
								width={logo.width}
								height={logo.height}
								class="shrink-0 h-auto max-h-[50px] md:max-h-[70px] lg:max-h-none w-[var(--logo-w)]"
								style={`--logo-w: ${logo.width}px;`}
							/>
						))}
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- Actualités Section -->
	<section id="actualites-section" class="bg-gris-clair py-12 md:py-16 lg:py-0 lg:h-[832px]">
		<Container>
			<!-- Header: Title + Button -->
			<div class="flex flex-col md:flex-row md:items-start md:justify-between lg:pt-[87px] mb-8 lg:mb-10 gap-4 md:gap-0">
				<div class="md:flex-1">
					<SectionHeading title="Actualités" />
				</div>
				<div class="shrink-0">
					<Button variant="outline-dark" href="/actualites">
						Découvrez toutes les actus
					</Button>
				</div>
			</div>

			<!-- Articles Grid -->
			<div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
				<!-- Large Featured Article -->
				<div class="lg:w-[57%]">
					<ArticleCard
						title={featuredLargeArticle.title}
						date={featuredLargeArticle.date}
						tag={featuredLargeArticle.tag}
						tagColor={featuredLargeArticle.tagColor}
						image={featuredLargeArticle.image}
						imageAlt={featuredLargeArticle.imageAlt}
						href="/actualites"
						size="lg"
					/>
				</div>

				<!-- Small Articles Stack -->
				<div class="lg:w-[43%] flex flex-col gap-6 lg:gap-5">
					{featuredSmallArticles.map((article) => (
						<ArticleCard
							title={article.title}
							date={article.date}
							tag={article.tag}
							tagColor={article.tagColor}
							image={article.image}
							imageAlt={article.imageAlt}
							href="/actualites"
							layout="horizontal"
						/>
					))}
				</div>
			</div>

			</Container>
	</section>

	<!-- Team / Carrières Section -->
	<section id="team-section" class="relative overflow-hidden py-12 md:py-16 lg:py-0 lg:h-[650px]">
		<!-- Team Photo -->
		<div data-anim="3" class="relative mx-auto max-w-[400px] md:max-w-[500px] lg:max-w-none lg:absolute lg:left-[77px] lg:top-0 lg:w-[643px] lg:h-[668px] overflow-hidden mb-10 lg:mb-0">
			<Image
				src={homeCarriere}
				alt="Deux collaborateurs Reunimer en tenue professionnelle"
				class="w-full h-full object-cover object-top"
				widths={[400, 643, 900]}
				sizes="(max-width: 1024px) 400px, 643px"
			/>
		</div>

		<!-- Text Content -->
		<div class="px-5 md:px-10 lg:px-0 lg:absolute lg:left-[757px] lg:top-[226px] lg:w-[552px] max-w-[550px]">
			<h2 data-anim="4" class="font-display text-[28px] md:text-[32px] lg:text-display-lg uppercase text-bleu-abysse leading-[1.1] lg:leading-[44.5px] mb-6">
				Rejoignez la team Reunimer
			</h2>
			<p data-anim="4" class="font-heading font-normal text-lg lg:text-heading-lg text-bleu-abysse leading-[1.461] mb-8 lg:w-[421px]">
				Chez Reunimer, nous mettons l'humain au centre de la chaîne de valeurs.
			</p>
			<div data-anim="4">
				<Button variant="outline-dark" href="/carrieres">
					Découvrez nos offres d'emploi
				</Button>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	@keyframes scroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
	.animate-scroll {
		animation: scroll 20s linear infinite;
	}
</style>

	<script>
		import {
			gsap,
			ANIMATION_TYPES,
			isReducedMotionPreferred,
			setAnimationInitial,
			toAnimation,
			createScrollTimeline,
		} from '../scripts/animation.js';

		function initGroupeAnimations() {
			const section = document.getElementById('groupe-section');
			if (!section || isReducedMotionPreferred()) return;

			const animEls = section.querySelectorAll('[data-anim]');
			const typeMap = {
				'1': ANIMATION_TYPES.APPEAR_Z,
				'2': ANIMATION_TYPES.FADE_LEFT,
				'3': ANIMATION_TYPES.FADE_UP,
			};

			// Set initial hidden states
			animEls.forEach((el) => {
				const type = typeMap[el.dataset.anim];
				if (type) setAnimationInitial(el, type);
			});

			// Create scroll-triggered timeline
			const tl = createScrollTimeline({ trigger: section, start: 'top 75%' });

			// Title — APPEAR_Z
			const title = section.querySelector('[data-anim="1"]');
			if (title) tl.add(toAnimation(title, ANIMATION_TYPES.APPEAR_Z));

			// Description + Button — FADE_LEFT (staggered)
			const fadeLeftEls = section.querySelectorAll('[data-anim="2"]');
			if (fadeLeftEls.length) tl.add(toAnimation(fadeLeftEls, ANIMATION_TYPES.FADE_LEFT, { stagger: 0.15 }), '-=0.4');

			// Images — FADE_UP (staggered)
			const images = section.querySelectorAll('[data-anim="3"]');
			if (images.length) tl.add(toAnimation(images, ANIMATION_TYPES.FADE_UP, { stagger: 0.15 }), '-=0.4');

		}

		function initRseAnimations() {
			const section = document.getElementById('rse-section');
			if (!section || isReducedMotionPreferred()) return;

			const animEls = section.querySelectorAll('[data-anim]');
			const typeMap = {
				'3': ANIMATION_TYPES.FADE_UP,
				'4': ANIMATION_TYPES.FADE_RIGHT,
			};

			animEls.forEach((el) => {
				const type = typeMap[el.dataset.anim];
				if (type) setAnimationInitial(el, type);
			});

			const tl = createScrollTimeline({ trigger: section, start: 'top 75%' });

			const image = section.querySelector('[data-anim="3"]');
			if (image) {
				tl.add(toAnimation(image, ANIMATION_TYPES.FADE_UP));
			}

			const textEls = section.querySelectorAll('[data-anim="4"]');
			if (textEls.length) {
				tl.add(
					toAnimation(textEls, ANIMATION_TYPES.FADE_RIGHT, { stagger: 0.15 }),
					'-=0.3'
				);
			}
		}

		function initActualitesAnimations() {
			const section = document.getElementById('actualites-section');
			if (!section || isReducedMotionPreferred()) return;

			gsap.set(section, { autoAlpha: 0 });

			const tl = createScrollTimeline({ trigger: section, start: 'top 75%' });
			tl.to(section, { autoAlpha: 1, duration: 1.8, ease: 'power2.inOut' });
		}

		function initTeamAnimations() {
			const section = document.getElementById('team-section');
			if (!section || isReducedMotionPreferred()) return;

			const animEls = section.querySelectorAll('[data-anim]');
			const typeMap = {
				'3': ANIMATION_TYPES.FADE_UP,
				'4': ANIMATION_TYPES.FADE_RIGHT,
			};

			animEls.forEach((el) => {
				const type = typeMap[el.dataset.anim];
				if (type) setAnimationInitial(el, type);
			});

			const tl = createScrollTimeline({ trigger: section, start: 'top 75%' });

			const image = section.querySelector('[data-anim="3"]');
			if (image) {
				tl.add(toAnimation(image, ANIMATION_TYPES.FADE_UP));
			}

			const textEls = section.querySelectorAll('[data-anim="4"]');
			if (textEls.length) {
				tl.add(
					toAnimation(textEls, ANIMATION_TYPES.FADE_RIGHT, { stagger: 0.15 }),
					'-=0.3'
				);
			}
		}

		initGroupeAnimations();
		initRseAnimations();
		initActualitesAnimations();
		initTeamAnimations();

		document.addEventListener('astro:after-swap', () => {
			initGroupeAnimations();
			initRseAnimations();
			initActualitesAnimations();
			initTeamAnimations();
		});
	</script>

<script>
	import { setupPanelHover, isReducedMotionPreferred } from '../scripts/animation.js';

	function initExpertiseHover() {
		if (isReducedMotionPreferred()) return;

		document.querySelectorAll('[data-expertise-card]').forEach((card) => {
			const panel = card.querySelector('[data-panel]');
			const revealEls = card.querySelectorAll('[data-reveal]');
			if (panel && revealEls.length) {
				setupPanelHover(card, panel, revealEls);
			}
		});
	}

	initExpertiseHover();
	document.addEventListener('astro:after-swap', initExpertiseHover);
</script>
