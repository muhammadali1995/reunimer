---
import PageLayout from '../layouts/PageLayout.astro';
import HomeHeroSection from '../components/sections/home/HomeHeroSection.astro';
import HomeGroupeSection from '../components/sections/home/HomeGroupeSection.astro';
import HomeExpertisesSection from '../components/sections/home/HomeExpertisesSection.astro';
import HomeRseSection from '../components/sections/home/HomeRseSection.astro';
import HomeFilialesSection from '../components/sections/home/HomeFilialesSection.astro';
import HomeActualitesSection from '../components/sections/home/HomeActualitesSection.astro';
import HomeTeamSection from '../components/sections/home/HomeTeamSection.astro';
---

<PageLayout>
	<HomeHeroSection />
	<HomeGroupeSection />
	<HomeExpertisesSection />
	<HomeRseSection />
	<HomeFilialesSection />
	<HomeActualitesSection />
	<HomeTeamSection />
</PageLayout>

<style>
	@keyframes scroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
	.animate-scroll {
		animation: scroll 20s linear infinite;
	}
</style>

<script>
	import { initHomePage } from '../scripts/homePage.js';

	initHomePage();
	document.addEventListener('astro:after-swap', initHomePage);
</script>
