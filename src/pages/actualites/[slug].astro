---
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Tag from '../../components/ui/Tag.astro';
import { articles, articleDetails } from '../../data/articles';

export const getStaticPaths: GetStaticPaths = () => {
  return Object.keys(articleDetails).map((slug) => ({
    params: { slug },
  }));
};

const { slug } = Astro.params as { slug: string };
const article = articles.find((a) => a.slug === slug)!;
const detail = articleDetails[slug]!;

const navArrows = [
  { label: 'Image précédente', direction: 'prev', path: 'M10 3L5 8L10 13' },
  { label: 'Image suivante', direction: 'next', path: 'M6 3L11 8L6 13' },
];

---

<PageLayout
  title={`${article.title} — Reunimer`}
  description={`Découvrez : ${article.title}`}
>
  <!-- Image Gallery -->
  <section class="bg-white pt-10 md:pt-16 lg:pt-[128px]">
    <Container>
      <div class="swiper overflow-hidden" data-article-gallery>
        <div class="swiper-wrapper">
          {detail.gallery.map((item, index) => (
            <div class="swiper-slide !w-full md:!w-[574px] lg:!w-[574px]">
              <div class="relative overflow-hidden">
                <Image
                  src={item.image}
                  alt={item.alt}
                  class="w-full h-[500px] object-cover"
                  loading={index < 3 ? 'eager' : 'lazy'}
                />
                {index === 0 && (
                  <div class="absolute top-[21px] left-[15px]">
                    <Tag color={article.tagColor}>{article.tag}</Tag>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Article Header -->
  <section class="bg-white pt-4 md:pt-6 lg:pt-[23px]">
    <Container>
      <div class="flex items-end justify-between">
        <!-- Date & Title -->
        <div>
          <time class="font-body font-medium text-label-sm leading-none text-brume-alize uppercase">
            {article.date}
          </time>
          <h1 class="mt-[6px] font-heading font-bold text-2xl md:text-heading-xl text-bleu-abysse leading-tight max-w-[525px]">
            {article.title}
          </h1>
        </div>

        <!-- Navigation Arrows -->
        <div class="flex items-center gap-3">
          {navArrows.map((arrow) => (
            <button
              type="button"
              class="flex items-center cursor-pointer justify-center w-[50px] h-[50px] rounded-full bg-turquoise-ocean text-white transition-colors duration-200 border border-transparent hover:bg-white hover:text-bleu-abysse hover:border-turquoise-ocean"
              aria-label={arrow.label}
              data-gallery-nav={arrow.direction}
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d={arrow.path} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Article Body -->
  <section class="bg-white pt-8 md:pt-10 lg:pt-[41px] pb-16 md:pb-24 lg:pb-[120px]">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-[50px] max-w-[1154px]">
        {detail.body.map((paragraph) => (
          <p class="font-heading font-normal text-base md:text-[20px] md:leading-[1.461] text-bleu-abysse">
            {paragraph}
          </p>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>

<script>
  import Swiper from 'swiper';
  import { Navigation } from 'swiper/modules';
  import 'swiper/css';

  let articleGallerySwiper;

  function initArticleGallery() {
    const slider = document.querySelector('[data-article-gallery]');
    const prevButton = document.querySelector('[data-gallery-nav="prev"]');
    const nextButton = document.querySelector('[data-gallery-nav="next"]');

    if (!slider || !prevButton || !nextButton) return;

    articleGallerySwiper?.destroy(true, true);

    articleGallerySwiper = new Swiper(slider, {
      modules: [Navigation],
      loop: true,
      speed: 650,
      allowTouchMove: true,
      slidesPerView: 'auto',
      spaceBetween: 10,
      slidesPerGroup: 1,
      navigation: {
        prevEl: prevButton,
        nextEl: nextButton,
      },
    });
  }

  initArticleGallery();
  document.addEventListener('astro:after-swap', initArticleGallery);
</script>
