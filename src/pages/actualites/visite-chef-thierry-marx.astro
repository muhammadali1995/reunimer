---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Tag from '../../components/ui/Tag.astro';
import articlePlaceholder from '../../assets/images/actus/article-4.jpg';
---

<PageLayout
  title="Visite du Chef Thierry Marx — Reunimer"
  description="Découvrez la visite du Chef Thierry Marx chez Reunimer."
>
  <!-- Image Gallery -->
  <section class="bg-white pt-10 md:pt-16 lg:pt-[128px]">
    <Container>
      <div class="flex flex-col md:flex-row gap-[10px]">
        <!-- Main Photo -->
        <div class="relative overflow-hidden md:w-[574px] md:flex-shrink-0 aspect-[574/498]">
          <Image
            src={articlePlaceholder}
            alt="Visite du Chef Thierry Marx"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
          />
          <div class="absolute top-[21px] left-[15px]">
            <Tag color="turquoise-ocean">EVENTS</Tag>
          </div>
        </div>
        <!-- Secondary Photo -->
        <div class="relative overflow-hidden md:w-[410px] md:flex-shrink-0 aspect-[410/498] hidden md:block">
          <Image
            src={articlePlaceholder}
            alt="Visite du Chef Thierry Marx"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <!-- Tertiary Photo (narrow) -->
        <div class="relative overflow-hidden md:flex-1 aspect-[152/498] hidden lg:block">
          <Image
            src={articlePlaceholder}
            alt="Visite du Chef Thierry Marx"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </Container>
  </section>

  <!-- Article Header -->
  <section class="bg-white pt-4 md:pt-6 lg:pt-[23px]">
    <Container>
      <div class="flex items-end justify-between">
        <!-- Date & Title -->
        <div>
          <time class="font-body font-medium text-label-sm leading-none text-brume-alize uppercase">
            11 FÉV. 2026
          </time>
          <h1 class="mt-[6px] font-heading font-bold text-2xl md:text-heading-xl text-bleu-abysse leading-tight max-w-[525px]">
            Visite du Chef Thierry Marx
          </h1>
        </div>

        <!-- Navigation Arrows -->
        <div class="flex items-center gap-3">
          <a
            href="#"
            class="flex items-center justify-center w-[50px] h-[50px] rounded-full bg-turquoise-ocean text-white transition-opacity hover:opacity-80"
            aria-label="Article précédent"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="#"
            class="flex items-center justify-center w-[50px] h-[50px] rounded-full bg-turquoise-ocean text-white transition-opacity hover:opacity-80"
            aria-label="Article suivant"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Article Body -->
  <section class="bg-white pt-8 md:pt-10 lg:pt-[41px] pb-16 md:pb-24 lg:pb-[120px]">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-[50px] max-w-[1154px]">
        <p class="font-heading font-normal text-base md:text-[20px] md:leading-[1.461] text-bleu-abysse">
          Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga. Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga. Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga.
        </p>
        <p class="font-heading font-normal text-base md:text-[20px] md:leading-[1.461] text-bleu-abysse">
          Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga. Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga. Ipsunda ime non cumquat emperchil etus etur, voluptatem et alit, tem dem excero id quo temposte sim hilicius, aut pa doluptatior reictatur sae volorecus et expeliquid quam la dem fuga.
        </p>
      </div>
    </Container>
  </section>
</PageLayout>
